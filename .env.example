# ─── Database (Supabase) ───
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ─── Auth ───
JWT_SECRET=CHANGE_ME_RANDOM_SECRET_64_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_RANDOM_SECRET_64_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── App ───
NODE_ENV=production
CORS_ORIGIN=https://yourdomain.cz

# ─── Email / SMTP ───
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@yourdomain.cz
SMTP_FROM_NAME=ifmio

# ─── Caddy / SSL ───
DOMAIN=yourdomain.cz
CADDY_EMAIL=admin@yourdomain.cz

# ─── Web ───
VITE_API_URL=/api/v1

# ─── Super Admin ───
SUPER_ADMIN_EMAILS=admin@yourdomain.cz
