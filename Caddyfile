{
	email {$CADDY_EMAIL:-admin@yourdomain.cz}
}

{$DOMAIN:-localhost} {

	log {
		output file /var/log/caddy/access.log {
			roll_size     100mb
			roll_keep     5
			roll_keep_for 720h
		}
	}

	header {
		X-Content-Type-Options    "nosniff"
		X-Frame-Options           "SAMEORIGIN"
		Referrer-Policy           "strict-origin-when-cross-origin"
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' https://*.ingest.sentry.io; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
		Permissions-Policy        "camera=(), microphone=(), geolocation=(), payment=()"
		-Server
	}

	# Upload limit for file endpoints
	handle /api/v1/documents/upload {
		request_body {
			max_size 25MB
		}
		reverse_proxy api:3000
	}

	handle /api/v1/residents/import/* {
		request_body {
			max_size 10MB
		}
		reverse_proxy api:3000
	}

	# API proxy
	handle /api/* {
		reverse_proxy api:3000 {
			health_uri      /api/v1/health
			health_interval 30s
			lb_try_duration 5s
		}
	}

	# Block dotfiles and sensitive paths (return 404 before SPA catch-all)
	@dotfiles {
		path_regexp dotfile ^/\.(env|git|docker|htaccess|htpasswd|npmrc|DS_Store)
	}
	respond @dotfiles 404

	# SPA (web)
	handle {
		reverse_proxy web:80
	}

	encode gzip zstd
}

www.{$DOMAIN:-localhost} {
	redir https://{$DOMAIN:-localhost}{uri} permanent
}
