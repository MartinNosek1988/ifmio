DATABASE_URL="postgresql://postgres.PROJECT_ID:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_ID.supabase.co:5432/postgres"
JWT_SECRET="CHANGE_THIS_TO_64_CHAR_RANDOM_STRING"
JWT_REFRESH_SECRET="CHANGE_THIS_TOO_DIFFERENT_FROM_ABOVE"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ─── EMAIL / SMTP ───
# Nastavte pro odesilani upominek emailem
# Testovani: pouzijte Mailtrap (https://mailtrap.io)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
SMTP_FROM_EMAIL=noreply@yourdomain.cz
SMTP_FROM_NAME=ifmio

# ─── SUPER ADMIN ───
# Comma-separated list of emails with super-admin access
SUPER_ADMIN_EMAILS=admin@ifmio.cz

# ─── SENTRY (optional) ───
# Leave empty to disable Sentry
SENTRY_DSN=
SENTRY_RELEASE=ifmio-api@1.0.0
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ─── AUDIT ───
AUDIT_LOG_RETENTION_DAYS=365

# ─── ENCRYPTION ───
# AES-256 encryption key for sensitive fields (min 32 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ─── MIO AI (optional) ───
# Anthropic API key for Mio AI assistant
# Leave empty to disable AI features
ANTHROPIC_API_KEY=

# ─── Communication Channels ─────────────────────
# GoSMS.cz (SMS)
GOSMS_CLIENT_ID=
GOSMS_CLIENT_SECRET=
GOSMS_CHANNEL_ID=

# DopisOnline (Česká pošta — physical letters)
DOPISONLINE_USERNAME=
DOPISONLINE_PASSWORD=
DOPISONLINE_SENDER_NAME=
DOPISONLINE_SENDER_STREET=
DOPISONLINE_SENDER_CITY=
DOPISONLINE_SENDER_ZIP=

# ISDS (Datové schránky)
ISDS_USERNAME=
ISDS_PASSWORD=
ISDS_DATABOX_ID=

# WhatsApp Business API (Meta Cloud API)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_BUSINESS_ID=
WHATSAPP_VERIFY_TOKEN=ifmio_whatsapp_verify_2026

# ─── Microsoft 365 (Graph API) ──────────────────
M365_CLIENT_ID=
M365_CLIENT_SECRET=
M365_TENANT_ID=
M365_TEAMS_WEBHOOK_URL=
M365_TEAMS_TEAM_ID=
M365_TEAMS_CHANNEL_ID=
M365_PLANNER_PLAN_ID=
M365_PLANNER_TICKET_BUCKET_ID=
M365_PLANNER_WO_BUCKET_ID=
M365_CALENDAR_USER_ID=
M365_SHAREPOINT_DRIVE_ID=
