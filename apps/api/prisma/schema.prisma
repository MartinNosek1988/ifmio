}

// ─── NOTIFICATIONS ───────────────────────────────────────────────

model Notification {
  id         String    @id @default(cuid())
  tenantId   String
  userId     String?
  type       String
  title      String
  body       String
  entityId   String?
  entityType String?
  url        String?
  isRead     Boolean   @default(false)
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, isRead, createdAt])
  @@index([userId, isRead])
  @@map("notifications")
}

// ─── LEASE AGREEMENTS ────────────────────────────────────────────

model LeaseAgreement {
  id              String         @id @default(uuid())
  tenantId        String
  propertyId      String
  unitId          String?
  residentId      String?
  contractNumber  String?
  contractType    ContractType   @default(najem)
  status          ContractStatus @default(aktivni)
  monthlyRent     Decimal        @db.Decimal(12, 2)
  deposit         Decimal?       @db.Decimal(12, 2)
  depositPaid     Decimal?       @db.Decimal(12, 2)
  startDate       DateTime
  endDate         DateTime?
  indefinite      Boolean        @default(false)
  noticePeriod    Int            @default(3)
  renewalType     RenewalType    @default(pisemna)
  terminatedAt    DateTime?
  terminationNote String?
  note            String?        @db.Text
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property Property  @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  unit     Unit?     @relation(fields: [unitId], references: [id], onDelete: SetNull)
  resident Resident? @relation(fields: [residentId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, endDate])
  @@index([propertyId])
  @@index([residentId])
  @@map("lease_agreements")
}

enum ContractType {
  najem
  podnajem
  sluzebni
  jiny
}

enum ContractStatus {
  aktivni
  ukoncena
  pozastavena
  pripravovana
}

enum RenewalType {
  pisemna
  automaticka
  nevztahuje
}

// ─── WORK ORDERS ─────────────────────────────────────────────────

model WorkOrder {
  id               String     @id @default(uuid())
  tenantId         String
  propertyId       String?
  unitId           String?
  assetId          String?
  helpdeskTicketId String?
  title            String
  description      String?    @db.Text
  workType         WorkType   @default(corrective)
  priority         WOPriority @default(normalni)
  status           WOStatus   @default(nova)
  assignee         String?
  requester        String?
  assigneeUserId   String?
  requesterUserId  String?
  dispatcherUserId String?
  deadline         DateTime?
  completedAt      DateTime?
  estimatedHours   Float?
  actualHours      Float?
  laborCost        Decimal?   @db.Decimal(12, 2)
  materialCost     Decimal?   @db.Decimal(12, 2)
  totalCost        Decimal?   @db.Decimal(12, 2)
  note             String?    @db.Text

  // Structured handover fields
  workSummary      String?    @db.Text
  findings         String?    @db.Text
  recommendation   String?    @db.Text

  // Completion requirements (overrides defaults)
  requirePhoto     Boolean    @default(false)
  requireHours     Boolean    @default(false)
  requireSummary   Boolean    @default(false)
  requireProtocol  Boolean    @default(false)

  // Dispatch to supplier
  supplierId              String?
  dispatchedAt            DateTime?
  dispatchedById          String?
  supplierNote            String?    @db.Text
  supplierConfirmedAt     DateTime?
  supplierEta             DateTime?
  supplierDeclinedAt      DateTime?
  supplierDeclineReason   String?

  // Completion
  completedPhotos  Json?
  completionNote   String?    @db.Text
  csatScore        Int?
  csatComment      String?

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property        Property?          @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  unit            Unit?              @relation(fields: [unitId], references: [id], onDelete: SetNull)
  asset           Asset?             @relation(fields: [assetId], references: [id], onDelete: SetNull)
  helpdeskTicket  HelpdeskTicket?    @relation(fields: [helpdeskTicketId], references: [id], onDelete: SetNull)
  assigneeUser    User?              @relation("WOAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  requesterUser   User?              @relation("WORequester", fields: [requesterUserId], references: [id], onDelete: SetNull)
  dispatcherUser  User?              @relation("WODispatcher", fields: [dispatcherUserId], references: [id], onDelete: SetNull)
  supplier        Party?             @relation("WorkOrderSupplier", fields: [supplierId], references: [id], onDelete: SetNull)
  dispatchedByUser User?             @relation("WODispatchedBy", fields: [dispatchedById], references: [id], onDelete: SetNull)
  comments        WorkOrderComment[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, priority])
  @@index([tenantId, deadline])
  @@index([propertyId])
  @@index([assetId])
  @@index([helpdeskTicketId])
  @@map("work_orders")
}

model WorkOrderComment {
  id          String   @id @default(uuid())
  workOrderId String
  author      String
  text        String   @db.Text
  createdAt   DateTime @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
  @@map("work_order_comments")
}

enum WorkType {
  corrective
  preventive
  inspection
  emergency
}

enum WOPriority {
  nizka
  normalni
  vysoka
  kriticka
}

enum WOStatus {
  nova
  v_reseni
  vyresena
  uzavrena
  zrusena
}

// ─── METERS ──────────────────────────────────────────────────────

model Meter {
  id              String    @id @default(uuid())
  tenantId        String
  propertyId      String?
  unitId          String?
  name            String
  serialNumber    String
  meterType       MeterType
  unit            String    @default("kWh")
  installDate     DateTime?
  calibrationDate DateTime?
  calibrationDue  DateTime?
  manufacturer    String?
  location        String?
  isActive        Boolean   @default(true)
  lastReading     Float?
  lastReadingDate DateTime?
  note            String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property Property?      @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  unitRel  Unit?          @relation(fields: [unitId], references: [id], onDelete: SetNull)
  readings MeterReading[]

  @@index([tenantId])
  @@map("meters")
}

model MeterReading {
  id          String   @id @default(uuid())
  meterId     String
  readingDate DateTime
  value       Float
  consumption Float?
  source      String   @default("manual")
  isInitial   Boolean  @default(false)
  readBy      String?
  note        String?
  createdAt   DateTime @default(now())

  meter Meter @relation(fields: [meterId], references: [id], onDelete: Cascade)

  @@index([meterId])
  @@map("meter_readings")
}

enum MeterType {
  elektrina
  voda_studena
  voda_tepla
  plyn
  teplo
}

// ─── CALENDAR EVENTS ────────────────────────────────────────────

model CalendarEvent {
  id          String       @id @default(uuid())
  tenantId    String
  propertyId  String?
  title       String
  eventType   CalEventType @default(ostatni)
  date        DateTime
  dateTo      DateTime?
  timeFrom    String?
  timeTo      String?
  location    String?
  description String?      @db.Text
  attendees   String[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, date])
  @@map("calendar_events")
}

enum CalEventType {
  schuze
  revize
  udrzba
  predani
  prohlidka
  ostatni
}

// ─── ASSET MANAGEMENT ────────────────────────────────────────────

model AssetType {
  id                   String   @id @default(uuid())
  tenantId             String
  name                 String
  code                 String
  category             String   @default("ostatni")
  description          String?  @db.Text
  manufacturer         String?
  model                String?
  defaultLocationLabel String?
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant               Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assets               Asset[]
  activityAssignments  AssetTypeRevisionType[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("asset_types")
}

model AssetTypeRevisionType {
  id                                String   @id @default(uuid())
  tenantId                          String
  assetTypeId                       String
  revisionTypeId                    String
  isRequired                        Boolean  @default(true)
  intervalDaysOverride              Int?
  reminderDaysOverride              Int?
  graceDaysOverride                 Int?
  requiresProtocolOverride          Boolean?
  requiresSupplierSignatureOverride Boolean?
  requiresCustomerSignatureOverride Boolean?
  note                              String?  @db.Text
  sortOrder                         Int      @default(0)
  createdAt                         DateTime @default(now())
  updatedAt                         DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assetType     AssetType      @relation(fields: [assetTypeId], references: [id], onDelete: Cascade)
  revisionType  RevisionType   @relation(fields: [revisionTypeId], references: [id], onDelete: Cascade)
  revisionPlans RevisionPlan[]

  @@unique([assetTypeId, revisionTypeId])
  @@index([tenantId])
  @@index([assetTypeId])
  @@index([revisionTypeId])
  @@map("asset_type_revision_types")
}

model Asset {
  id              String        @id @default(uuid())
  tenantId        String
  propertyId      String?
  unitId          String?
  assetTypeId     String?
  name            String
  category        AssetCategory @default(ostatni)
  manufacturer    String?
  model           String?
  serialNumber    String?
  location        String?
  status          AssetStatus   @default(aktivni)
  purchaseDate    DateTime?
  purchaseValue   Decimal?      @db.Decimal(12, 2)
  warrantyUntil   DateTime?
  serviceInterval Int? // months
  lastServiceDate DateTime?
  nextServiceDate DateTime?
  notes           String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  tenant           Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property         Property?            @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  unit             Unit?                @relation(fields: [unitId], references: [id], onDelete: SetNull)
  assetType        AssetType?           @relation(fields: [assetTypeId], references: [id], onDelete: SetNull)
  serviceRecords       AssetServiceRecord[]
  revisionPlans        RevisionPlan[]       @relation("AssetRevisionPlans")
  revisionSubjects     RevisionSubject[]    @relation("AssetRevisionSubjects")
  qrCodes              AssetQrCode[]
  qrScanEvents         AssetQrScanEvent[]
  fieldCheckExecutions AssetFieldCheckExecution[]
  helpdeskTickets      HelpdeskTicket[]
  workOrders           WorkOrder[]
  recurringPlans       RecurringActivityPlan[]

  @@index([tenantId])
  @@index([propertyId])
  @@index([assetTypeId])
  @@map("assets")
}

// ─── ASSET QR CODES ───────────────────────────────────────────────

model AssetQrCode {
  id                 String        @id @default(uuid())
  tenantId           String
  assetId            String
  token              String        @unique
  humanCode          String
  status             AssetQrStatus @default(active)
  labelVersion       Int           @default(1)
  generatedAt        DateTime      @default(now())
  printedAt          DateTime?
  replacedAt         DateTime?
  replacedByQrCodeId String?
  notes              String?       @db.Text

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  asset        Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  replacedBy   AssetQrCode?  @relation("QrReplacement", fields: [replacedByQrCodeId], references: [id])
  replacements AssetQrCode[] @relation("QrReplacement")
  scanEvents   AssetQrScanEvent[]

  @@index([tenantId])
  @@index([assetId])
  @@index([token])
  @@index([assetId, status])
  @@map("asset_qr_codes")
}

enum AssetQrStatus {
  active
  replaced
  disabled
}

enum AssetCategory {
  tzb
  stroje
  vybaveni
  vozidla
  it
  ostatni
}

enum AssetStatus {
  aktivni
  servis
  vyrazeno
  neaktivni
}

model AssetServiceRecord {
  id          String   @id @default(uuid())
  assetId     String
  tenantId    String
  date        DateTime
  type        String // preventivni, oprava, revize, kalibrace
  description String?  @db.Text
  cost        Decimal? @db.Decimal(12, 2)
  supplier    String?
  createdAt   DateTime @default(now())

  asset  Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([tenantId])
  @@map("asset_service_records")
}

// ─── QR SCAN AUDIT & FIELD CHECKS ────────────────────────────────

enum QrScanOutcome {
  resolved
  invalid
  replaced
  disabled
  unauthorized
}

enum QrScanSource {
  qr_scan
  manual_open
  redirected_after_login
}

model AssetQrScanEvent {
  id                 String          @id @default(uuid())
  tenantId           String
  assetId            String
  assetQrCodeId      String?
  userId             String
  outcome            QrScanOutcome   @default(resolved)
  source             QrScanSource    @default(qr_scan)
  scannedAt          DateTime        @default(now())
  appVersion         String?
  deviceInfo         String?
  ipAddress          String?
  userAgent          String?
  latitude           Decimal?        @db.Decimal(10, 7)
  longitude          Decimal?        @db.Decimal(10, 7)
  accuracyMeters     Decimal?        @db.Decimal(8, 2)
  locationCapturedAt DateTime?
  notes              String?         @db.Text

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  asset       Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  assetQrCode AssetQrCode? @relation(fields: [assetQrCodeId], references: [id], onDelete: SetNull)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  fieldChecks AssetFieldCheckExecution[]

  @@index([tenantId])
  @@index([assetId])
  @@index([userId])
  @@index([assetQrCodeId])
  @@index([scannedAt])
  @@map("asset_qr_scan_events")
}

enum FieldCheckType {
  daily_check
  inspection
  service_check
  route_check
  custom
}

enum FieldCheckStatus {
  started
  completed
  failed
  cancelled
}

enum FieldCheckResult {
  ok
  issue_found
  needs_follow_up
  not_accessible
}

enum FieldCheckConfidenceLevel {
  low
  medium
  high
}

enum FieldCheckSignalType {
  qr_scan
  gps
  photo
  reading
  checklist
  manual_code
}

model AssetFieldCheckExecution {
  id               String                    @id @default(uuid())
  tenantId         String
  assetId          String
  userId           String
  scanEventId      String?
  revisionPlanId   String?
  checkType        FieldCheckType            @default(daily_check)
  startedAt        DateTime                  @default(now())
  completedAt      DateTime?
  status           FieldCheckStatus          @default(started)
  result           FieldCheckResult?
  notes            String?                   @db.Text
  confidenceLevel  FieldCheckConfidenceLevel @default(low)
  confidenceScore  Int                       @default(0)

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  asset        Asset             @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  scanEvent    AssetQrScanEvent? @relation(fields: [scanEventId], references: [id], onDelete: SetNull)
  revisionPlan RevisionPlan?     @relation(fields: [revisionPlanId], references: [id], onDelete: SetNull)
  signals      AssetFieldCheckSignal[]

  @@index([tenantId])
  @@index([assetId])
  @@index([userId])
  @@index([scanEventId])
  @@index([startedAt])
  @@map("asset_field_check_executions")
}

model AssetFieldCheckSignal {
  id                    String               @id @default(uuid())
  fieldCheckExecutionId String
  signalType            FieldCheckSignalType
  isValid               Boolean?
  payloadJson           Json
  createdAt             DateTime             @default(now())

  execution AssetFieldCheckExecution @relation(fields: [fieldCheckExecutionId], references: [id], onDelete: Cascade)

  @@index([fieldCheckExecutionId])
  @@map("asset_field_check_signals")
}

// ═══════════════════════════════════════════════════════════════════
// PRINCIPAL & FINANCIAL CONTEXT LAYER — Enums
// ═══════════════════════════════════════════════════════════════════

enum PartyType {
  person
  company
  hoa
  organization_unit
}

enum PrincipalType {
  hoa
  individual_owner
  corporate_owner
  tenant_client
  mixed_client
}

enum ManagementType {
  hoa_management
  rental_management
  technical_management
  accounting_management
  admin_management
}

enum ManagementScope {
  whole_property
  selected_units
}

enum FinancialScopeType {
  property
  principal
  manager
}

enum OwnershipRole {
  legal_owner
  beneficial_owner
  managing_owner
  silent_coowner
}

enum TenancyType {
  lease
  sublease
  occupancy
  short_term
}

enum TenancyRole {
  tenant
  co_tenant
  occupant
}

// ═══════════════════════════════════════════════════════════════════
// LAYER 1: CORE — Party (universal identity)
// ═══════════════════════════════════════════════════════════════════

model Party {
  id                    String    @id @default(cuid())
  tenantId              String

  type                  PartyType
  displayName           String
  firstName             String?
  lastName              String?
  companyName           String?

  ic                    String?   @db.VarChar(20)
  dic                   String?   @db.VarChar(20)
  vatId                 String?   @db.VarChar(32)

  email                 String?
  phone                 String?
  website               String?

  street                String?
  street2               String?
  city                  String?
  postalCode            String?
  countryCode           String?   @db.Char(2)

  dataBoxId             String?
  bankAccount           String?
  bankCode              String?
  iban                  String?

  isActive              Boolean   @default(true)
  note                  String?   @db.Text

  // ARES-sourced fields
  pravniForma           String?            // název právní formy z ARES (např. "Společenství vlastníků")
  pravniFormaKod        String?            // kód právní formy (např. "961")
  datumVzniku           DateTime?          // datum vzniku subjektu dle ARES
  datumZaniku           DateTime?          // datum zániku — pokud vyplněno, subjekt je zaniklý
  czNace                Json?              // pole NACE kódů z ARES
  zastupci              Json?              // statutární zástupci z ARES [{jmeno, prijmeni, funkce}]

  // GDPR (ZT-W5-01)
  gdprErased            Boolean   @default(false)
  gdprErasedAt          DateTime?

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  tenant                Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  principals            Principal[]
  principalOwnerships   PrincipalOwner[]
  propertyOwnerships    PropertyOwnership[]
  unitOwnerships        UnitOwnership[]
  tenancies             Tenancy[]
  residents             Resident[]
  users                 User[]             @relation("UserParty")
  assemblyAttendances   AssemblyAttendee[]
  perRollamBallots      PerRollamBallot[]
  suppliedWorkOrders    WorkOrder[]        @relation("WorkOrderSupplier")

  @@index([tenantId, displayName])
  @@index([tenantId, ic])
  @@index([tenantId, type])
  @@map("parties")
}

// ═══════════════════════════════════════════════════════════════════
// LAYER 2: REAL-WORLD RELATIONS
// ═══════════════════════════════════════════════════════════════════

model PropertyOwnership {
  id                    String        @id @default(cuid())
  tenantId              String
  propertyId            String
  partyId               String

  role                  OwnershipRole @default(legal_owner)
  shareNumerator        Int?
  shareDenominator      Int?
  sharePercent          Decimal?      @db.Decimal(7, 4)

  validFrom             DateTime?
  validTo               DateTime?
  isActive              Boolean       @default(true)
  note                  String?       @db.Text

  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  tenant                Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property              Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  party                 Party         @relation(fields: [partyId], references: [id], onDelete: Restrict)

  @@index([tenantId, propertyId])
  @@index([tenantId, partyId])
  @@unique([propertyId, partyId, validFrom])
  @@map("property_ownerships")
}

model UnitOwnership {
  id                    String        @id @default(cuid())
  tenantId              String
  unitId                String
  partyId               String

  role                  OwnershipRole @default(legal_owner)
  shareNumerator        Int?
  shareDenominator      Int?
  sharePercent          Decimal?      @db.Decimal(7, 4)

  validFrom             DateTime?
  validTo               DateTime?
  isActive              Boolean       @default(true)
  variableSymbol        String?       // VS pro párování plateb
  note                  String?       @db.Text

  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  tenant                Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unit                  Unit          @relation(fields: [unitId], references: [id], onDelete: Cascade)
  party                 Party         @relation(fields: [partyId], references: [id], onDelete: Restrict)

  @@index([tenantId, unitId])
  @@index([tenantId, partyId])
  @@unique([unitId, partyId, validFrom])
  @@map("unit_ownerships")
}

model Tenancy {
  id                    String       @id @default(cuid())
  tenantId              String
  unitId                String
  partyId               String

  type                  TenancyType
  role                  TenancyRole  @default(tenant)

  contractNo            String?      @db.VarChar(100)
  validFrom             DateTime?
  validTo               DateTime?
  moveInDate            DateTime?
  moveOutDate           DateTime?

  rentAmount            Decimal?     @db.Decimal(12, 2)
  serviceAdvanceAmount  Decimal?     @db.Decimal(12, 2)
  depositAmount         Decimal?     @db.Decimal(12, 2)

  isActive              Boolean      @default(true)
  variableSymbol        String?      // VS pro párování plateb
  note                  String?      @db.Text

  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  tenant                Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unit                  Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)
  party                 Party        @relation(fields: [partyId], references: [id], onDelete: Restrict)

  @@index([tenantId, unitId])
  @@index([tenantId, partyId])
  @@index([tenantId, isActive])
  @@map("tenancies")
}

// ═══════════════════════════════════════════════════════════════════
// LAYER 3: BUSINESS / SERVICE — Principal, Contract
// ═══════════════════════════════════════════════════════════════════

model Principal {
  id                    String        @id @default(cuid())
  tenantId              String
  partyId               String

  type                  PrincipalType
  code                  String?       @db.VarChar(50)
  displayName           String

  isActive              Boolean       @default(true)
  validFrom             DateTime?
  validTo               DateTime?
  note                  String?       @db.Text

  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  tenant                Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  party                 Party         @relation(fields: [partyId], references: [id], onDelete: Restrict)

  owners                PrincipalOwner[]
  managementContracts   ManagementContract[]
  financialContexts     FinancialContext[]
  assemblyAttendances   AssemblyAttendee[]
  perRollamBallots      PerRollamBallot[]

  @@index([tenantId, partyId])
  @@index([tenantId, displayName])
  @@unique([tenantId, code])
  @@map("principals")
}

model PrincipalOwner {
  id                    String        @id @default(cuid())
  tenantId              String
  principalId           String
  partyId               String

  role                  OwnershipRole @default(silent_coowner)
  shareNumerator        Int?
  shareDenominator      Int?
  sharePercent          Decimal?      @db.Decimal(7, 4)

  isManaging            Boolean       @default(false)

  validFrom             DateTime?
  validTo               DateTime?
  note                  String?       @db.Text

  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  tenant                Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  principal             Principal     @relation(fields: [principalId], references: [id], onDelete: Cascade)
  party                 Party         @relation(fields: [partyId], references: [id], onDelete: Restrict)

  @@index([tenantId, principalId])
  @@index([tenantId, partyId])
  @@unique([principalId, partyId, validFrom])
  @@map("principal_owners")
}

model ManagementContract {
  id                    String           @id @default(cuid())
  tenantId              String
  principalId           String
  propertyId            String

  type                  ManagementType
  scope                 ManagementScope  @default(whole_property)

  contractNo            String?          @db.VarChar(100)
  name                  String?
  validFrom             DateTime?
  validTo               DateTime?
  isActive              Boolean          @default(true)
  note                  String?          @db.Text

  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  tenant                Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  principal             Principal        @relation(fields: [principalId], references: [id], onDelete: Restrict)
  property              Property         @relation(fields: [propertyId], references: [id], onDelete: Restrict)

  units                 ManagementContractUnit[]
  financialContexts     FinancialContext[]

  @@index([tenantId, propertyId])
  @@index([tenantId, principalId])
  @@index([tenantId, type, isActive])
  @@map("management_contracts")
}

model ManagementContractUnit {
  id                    String             @id @default(cuid())
  tenantId              String
  managementContractId  String
  unitId                String

  createdAt             DateTime           @default(now())

  tenant                Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  managementContract    ManagementContract @relation(fields: [managementContractId], references: [id], onDelete: Cascade)
  unit                  Unit               @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([managementContractId, unitId])
  @@index([tenantId, unitId])
  @@map("management_contract_units")
}

// ═══════════════════════════════════════════════════════════════════
// LAYER 4: FINANCE — FinancialContext
// ═══════════════════════════════════════════════════════════════════

model FinancialContext {
  id                    String              @id @default(cuid())
  tenantId              String
  principalId           String?
  propertyId            String?
  managementContractId  String?

  scopeType             FinancialScopeType
  code                  String?             @db.VarChar(50)
  displayName           String

  currency              String              @default("CZK") @db.Char(3)
  vatEnabled            Boolean             @default(false)
  vatPayer              Boolean             @default(false)

  invoicePrefix         String?             @db.VarChar(20)
  creditNotePrefix      String?             @db.VarChar(20)
  orderPrefix           String?             @db.VarChar(20)

  accountingSystem      String?             @db.VarChar(50)
  brandingName          String?
  brandingEmail         String?
  brandingPhone         String?
  brandingWebsite       String?

  dopisOnlineUsername    String?
  dopisOnlineSender     String?

  isActive              Boolean             @default(true)
  note                  String?             @db.Text

  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  tenant                Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  principal             Principal?          @relation(fields: [principalId], references: [id], onDelete: Restrict)
  property              Property?           @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  managementContract    ManagementContract? @relation(fields: [managementContractId], references: [id], onDelete: SetNull)

  bankAccounts          BankAccount[]
  bankTransactions      BankTransaction[]
  invoices              Invoice[]
  prescriptions         Prescription[]
  settlements           Settlement[]

  @@index([tenantId, principalId])
  @@index([tenantId, propertyId])
  @@index([tenantId, managementContractId])
  @@unique([tenantId, code])
  @@map("financial_contexts")
}

// ═══════════════════════════════════════════════════════════════════
// ANNUAL SETTLEMENT (Roční vyúčtování)
// ═══════════════════════════════════════════════════════════════════

model Settlement {
  id                  String            @id @default(cuid())
  tenantId            String
  propertyId          String
  financialContextId  String
  billingPeriodId     String?

  name                String
  periodFrom          DateTime
  periodTo            DateTime
  status              SettlementStatus  @default(draft)

  totalHeatingCost    Decimal?          @db.Decimal(12, 2)
  totalHotWaterCost   Decimal?          @db.Decimal(12, 2)
  heatingBasicPercent Int               @default(50)
  hotWaterBasicPercent Int              @default(30)
  buildingEnergyClass String?           @db.VarChar(2)
  totalHeatedArea     Decimal?          @db.Decimal(10, 2)

  calculatedAt        DateTime?
  approvedAt          DateTime?
  approvedBy          String?
  note                String?           @db.Text

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  tenant              Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property            Property          @relation(fields: [propertyId], references: [id])
  financialContext    FinancialContext   @relation(fields: [financialContextId], references: [id])
  billingPeriod       BillingPeriod?    @relation(fields: [billingPeriodId], references: [id])

  items               SettlementItem[]
  costEntries         SettlementCost[]

  @@index([tenantId, propertyId])
  @@index([tenantId, status])
  @@map("settlements")
}

enum SettlementStatus {
  draft
  calculated
  approved
  sent
  closed
}

model SettlementCost {
  id              String             @id @default(cuid())
  settlementId    String

  costType        SettlementCostType
  name            String
  totalAmount     Decimal            @db.Decimal(12, 2)
  invoiceId       String?

  distributionKey DistributionKey
  basicPercent    Int?

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  settlement      Settlement         @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@index([settlementId])
  @@map("settlement_costs")
}

enum SettlementCostType {
  heating
  hot_water
  cold_water
  sewage
  elevator
  cleaning
  lighting
  waste
  other
}

enum DistributionKey {
  heated_area
  floor_area
  person_count
  meter_reading
  ownership_share
  equal
  custom
}

model SettlementItem {
  id                  String   @id @default(cuid())
  settlementId        String
  unitId              String

  heatingBasic        Decimal  @db.Decimal(12, 2) @default(0)
  heatingConsumption  Decimal  @db.Decimal(12, 2) @default(0)
  heatingTotal        Decimal  @db.Decimal(12, 2) @default(0)
  heatingCorrected    Decimal  @db.Decimal(12, 2) @default(0)

  hotWaterBasic       Decimal  @db.Decimal(12, 2) @default(0)
  hotWaterConsumption Decimal  @db.Decimal(12, 2) @default(0)
  hotWaterTotal       Decimal  @db.Decimal(12, 2) @default(0)

  otherCosts          Decimal  @db.Decimal(12, 2) @default(0)

  totalCost           Decimal  @db.Decimal(12, 2) @default(0)
  totalAdvances       Decimal  @db.Decimal(12, 2) @default(0)
  balance             Decimal  @db.Decimal(12, 2) @default(0)

  heatedArea          Decimal? @db.Decimal(10, 2)
  personCount         Int?
  meterReading        Decimal? @db.Decimal(12, 3)
  waterReading        Decimal? @db.Decimal(12, 3)

  costBreakdown       Json?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  settlement          Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  unit                Unit       @relation(fields: [unitId], references: [id])

  @@unique([settlementId, unitId])
  @@index([settlementId])
  @@map("settlement_items")
}

// ═══════════════════════════════════════════════════════════════════
// COMMUNICATION OUTBOX
// ═══════════════════════════════════════════════════════════════════

model OutboxLog {
  id              String    @id @default(cuid())
  tenantId        String
  channel         String    @db.VarChar(20)   // email, sms, letter, isds, whatsapp
  recipient       String                       // email, phone, dataBoxId, or "address"
  subject         String?
  status          String    @db.VarChar(20)   // sent, failed, pending
  externalId      String?                      // Provider's message ID
  error           String?   @db.Text
  cost            Decimal?  @db.Decimal(8, 2)
  metadata        Json?
  createdAt       DateTime  @default(now())

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, channel])
  @@index([tenantId, createdAt])
  @@map("outbox_logs")
}

// ─── KANBAN ──────────────────────────────────────────────────────────

model KanbanTask {
  id          String         @id @default(uuid())
  tenantId    String
  propertyId  String?
  title       String
  description String?        @db.Text
  priority    KanbanPriority @default(medium)
  status      KanbanStatus   @default(backlog)
  assigneeId  String?
  dueDate     DateTime?
  tags        String[]       @default([])
  sortOrder   Int            @default(0)
  createdById String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property  Property? @relation(fields: [propertyId], references: [id])
  assignee  User?     @relation("KanbanTaskAssignee", fields: [assigneeId], references: [id])
  createdBy User      @relation("KanbanTaskCreator", fields: [createdById], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, assigneeId])
  @@map("kanban_tasks")
}

enum KanbanPriority {
  low
  medium
  high
  urgent
}

enum KanbanStatus {
  backlog
  todo
  in_progress
  review
  done
}

model UserFeature {
  id        String   @id @default(uuid())
  userId    String
  feature   String
  enabled   Boolean  @default(true)
  config    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, feature])
  @@map("user_features")
}

// ─── REVOKED TOKENS (Zero Trust W3 — token blacklist DB fallback) ────

model RevokedToken {
  id        String   @id @default(uuid())
  jti       String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
  @@map("revoked_tokens")
}

// ─── API KEYS (Zero Trust W4 — integration API keys) ─────────────────

model ApiKey {
  id          String    @id @default(uuid())
  tenantId    String
  userId      String
  name        String
  keyHash     String    @unique        // SHA-256 hash of the actual key
  keyPrefix   String                   // first 8 chars for identification
  scopes      String[]                 // e.g. ['properties:read', 'units:read']
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  lastUsedIp  String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([keyHash])
  @@map("api_keys")
}

// ─── LOGIN RISK LOG (Zero Trust W4 — adaptive risk scoring) ──────────

model LoginRiskLog {
  id            String   @id @default(uuid())
  userId        String
  tenantId      String?
  ipAddress     String?
  userAgent     String?
  country       String?
  city          String?
  lat           Float?
  lon           Float?
  riskScore     Int      @default(0)   // 0–100
  riskFactors   Json?                  // array of { factor, score, detail }
  action        String                 // 'allow' | 'challenge' | 'block'
  loginSuccess  Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
  @@index([tenantId, createdAt])
  @@map("login_risk_logs")
}

// ─── UNIT GROUPS (E2 — uspořádání jednotek) ──────────────────────────

model UnitGroup {
  id          String        @id @default(uuid())
  tenantId    String
  propertyId  String
  name        String
  type        UnitGroupType @default(custom)
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property    Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  memberships UnitGroupMembership[]

  @@index([tenantId, propertyId])
  @@map("unit_groups")
}

model UnitGroupMembership {
  id          String    @id @default(uuid())
  unitGroupId String
  unitId      String

  unitGroup   UnitGroup @relation(fields: [unitGroupId], references: [id], onDelete: Cascade)
  unit        Unit      @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitGroupId, unitId])
  @@map("unit_group_memberships")
}

enum UnitGroupType {
  entrance
  floor
  custom
}

// ─── ASSEMBLY (SHROMÁŽDĚNÍ SVJ) ──────────────────────────────────────────────

model Assembly {
  id              String         @id @default(cuid())
  tenantId        String
  propertyId      String

  title           String
  description     String?
  assemblyNumber  Int

  scheduledAt     DateTime
  location        String

  status          AssemblyStatus @default(DRAFT)

  startedAt       DateTime?
  endedAt         DateTime?

  totalShares     Decimal?       @db.Decimal(12, 6)
  presentShares   Decimal?       @db.Decimal(12, 6)
  isQuorate       Boolean?

  notes           String?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  property        Property       @relation(fields: [propertyId], references: [id])
  agendaItems     AssemblyAgendaItem[]
  attendees       AssemblyAttendee[]
  hardwareSession HardwareVotingSession?

  @@index([tenantId])
  @@index([tenantId, propertyId])
  @@map("assemblies")
}

enum AssemblyStatus {
  DRAFT
  PUBLISHED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model AssemblyAgendaItem {
  id              String         @id @default(cuid())
  assemblyId      String

  orderNumber     Int
  title           String
  description     String?

  requiresVote    Boolean        @default(true)
  majorityType    MajorityType   @default(NADPOLOVICNI_PRITOMNYCH)

  result          VoteResult?
  votesFor        Decimal?       @db.Decimal(12, 6)
  votesAgainst    Decimal?       @db.Decimal(12, 6)
  votesAbstain    Decimal?       @db.Decimal(12, 6)

  // Per-item quorum snapshot
  presentSharesAtVote  Decimal?  @db.Decimal(12, 6)
  isQuorateAtVote      Boolean?
  garageInternalVotes  Json?     // { unitId: { for, against, abstain, result } }

  isCounterProposal   Boolean   @default(false)
  parentItemId        String?

  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  assembly        Assembly       @relation(fields: [assemblyId], references: [id], onDelete: Cascade)
  parentItem      AssemblyAgendaItem? @relation("CounterProposals", fields: [parentItemId], references: [id])
  counterProposals AssemblyAgendaItem[] @relation("CounterProposals")
  votes           AssemblyVote[]

  @@index([assemblyId])
  @@map("assembly_agenda_items")
}

enum MajorityType {
  NADPOLOVICNI_PRITOMNYCH
  NADPOLOVICNI_VSECH
  KVALIFIKOVANA
  JEDNOMYSLNA
}

enum VoteResult {
  SCHVALENO
  NESCHVALENO
  NEUSNASENO
}

model AssemblyAttendee {
  id              String         @id @default(cuid())
  assemblyId      String

  principalId     String?
  partyId         String?
  name            String

  unitIds         String[]
  totalShare      Decimal        @db.Decimal(12, 6)

  isPresent       Boolean        @default(true)
  registeredAt    DateTime       @default(now())
  leftAt          DateTime?

  hasPowerOfAttorney  Boolean    @default(false)
  powerOfAttorneyFrom String?

  keypadId        String?

  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  assembly        Assembly       @relation(fields: [assemblyId], references: [id], onDelete: Cascade)
  principal       Principal?     @relation(fields: [principalId], references: [id])
  party           Party?         @relation(fields: [partyId], references: [id])
  votes           AssemblyVote[]
  keypadAssignments AttendeeKeypadAssignment[]

  @@index([assemblyId])
  @@map("assembly_attendees")
}

model AssemblyVote {
  id              String         @id @default(cuid())
  agendaItemId    String
  attendeeId      String

  choice          VoteChoice
  shareWeight     Decimal        @db.Decimal(12, 6)

  keypadId        String?
  receivedAt      DateTime?

  createdAt       DateTime       @default(now())

  agendaItem      AssemblyAgendaItem @relation(fields: [agendaItemId], references: [id], onDelete: Cascade)
  attendee        AssemblyAttendee   @relation(fields: [attendeeId], references: [id], onDelete: Cascade)

  @@unique([agendaItemId, attendeeId])
  @@index([agendaItemId])
  @@map("assembly_votes")
}

enum VoteChoice {
  ANO
  NE
  ZDRZET
}

// ─── PER ROLLAM VOTING ──────────────────────────────────────────────────────

model PerRollamVoting {
  id                String              @id @default(cuid())
  tenantId          String
  propertyId        String

  title             String
  description       String?
  votingNumber      Int

  publishedAt       DateTime?
  deadline          DateTime
  resultsNotifiedAt DateTime?

  status            PerRollamStatus     @default(DRAFT)

  totalShares       Decimal?            @db.Decimal(12, 6)
  respondedShares   Decimal?            @db.Decimal(12, 6)
  isQuorate         Boolean?

  documentIds       String[]

  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  property          Property            @relation(fields: [propertyId], references: [id])
  items             PerRollamItem[]
  ballots           PerRollamBallot[]

  @@index([tenantId])
  @@index([tenantId, propertyId])
  @@map("per_rollam_votings")
}

enum PerRollamStatus {
  DRAFT
  PUBLISHED
  CLOSED
  COMPLETED
  CANCELLED
}

model PerRollamItem {
  id              String              @id @default(cuid())
  votingId        String

  orderNumber     Int
  title           String
  description     String?
  majorityType    MajorityType        @default(NADPOLOVICNI_VSECH)

  result          VoteResult?
  votesFor        Decimal?            @db.Decimal(12, 6)
  votesAgainst    Decimal?            @db.Decimal(12, 6)
  votesAbstain    Decimal?            @db.Decimal(12, 6)

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  voting          PerRollamVoting     @relation(fields: [votingId], references: [id], onDelete: Cascade)
  responses       PerRollamResponse[]

  @@index([votingId])
  @@map("per_rollam_items")
}

model PerRollamBallot {
  id                String              @id @default(cuid())
  votingId          String

  principalId       String?
  partyId           String?
  name              String
  unitIds           String[]
  totalShare        Decimal             @db.Decimal(12, 6)

  status            BallotStatus        @default(PENDING)
  submittedAt       DateTime?
  submissionMethod  BallotMethod?

  accessToken       String?             @unique
  tokenExpiresAt    DateTime?

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  voting            PerRollamVoting     @relation(fields: [votingId], references: [id], onDelete: Cascade)
  principal         Principal?          @relation(fields: [principalId], references: [id])
  party             Party?              @relation(fields: [partyId], references: [id])
  responses         PerRollamResponse[]

  @@index([votingId])
  @@index([accessToken])
  @@map("per_rollam_ballots")
}

enum BallotStatus {
  PENDING
  SUBMITTED
  MANUAL_ENTRY
}

enum BallotMethod {
  ONLINE
  PAPER_UPLOAD
  MANUAL
}

model PerRollamResponse {
  id              String              @id @default(cuid())
  itemId          String
  ballotId        String

  choice          VoteChoice
  shareWeight     Decimal             @db.Decimal(12, 6)

  createdAt       DateTime            @default(now())

  item            PerRollamItem       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  ballot          PerRollamBallot     @relation(fields: [ballotId], references: [id], onDelete: Cascade)

  @@unique([itemId, ballotId])
  @@map("per_rollam_responses")
}

// ─── HARDWARE VOTING SESSION ─────────────────────────────────────────────────

model HardwareVotingSession {
  id              String              @id @default(cuid())
  assemblyId      String              @unique
  tenantId        String

  bridgeApiKey    String              @unique @default(cuid())
  channelId       Int                 @default(1)
  receiverMode    ReceiverMode        @default(USB)

  isActive        Boolean             @default(false)
  currentItemId   String?
  votingOpen      Boolean             @default(false)

  connectedKeypads Int                @default(0)
  lastPingAt      DateTime?

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  assembly        Assembly            @relation(fields: [assemblyId], references: [id])

  @@index([tenantId])
  @@index([bridgeApiKey])
  @@map("hardware_voting_sessions")
}

enum ReceiverMode {
  USB
  TCP_IP
}

enum GarageVotingRule {
  PRESENT_MAJORITY
  ALL_OWNERS_MAJORITY
}

model AttendeeKeypadAssignment {
  id            String   @id @default(cuid())
  attendeeId    String
  keypadId      String
  unitIds       String[]
  shareWeight   Decimal  @db.Decimal(12, 6)

  createdAt     DateTime @default(now())

  attendee      AssemblyAttendee @relation(fields: [attendeeId], references: [id], onDelete: Cascade)

  @@unique([attendeeId, keypadId])
  @@index([attendeeId])
  @@map("attendee_keypad_assignments")
}

// ─── FLOOR PLANS ─────────────────────────────────────────────────────────────

model FloorPlan {
  id                  String          @id @default(cuid())
  tenantId            String
  propertyId          String
  floor               Int
  label               String?
  imageUrl            String
  imageWidth          Int
  imageHeight         Int
  scaleMetersPerPixel Float?
  sortOrder           Int             @default(0)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  property            Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  zones               FloorPlanZone[]

  @@index([tenantId, propertyId])
  @@map("floor_plans")
}

model FloorPlanZone {
  id          String        @id @default(cuid())
  floorPlanId String
  unitId      String?
  label       String?
  zoneType    FloorZoneType @default(UNIT)
  polygon     Json
  color       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  floorPlan   FloorPlan     @relation(fields: [floorPlanId], references: [id], onDelete: Cascade)
  unit        Unit?         @relation(fields: [unitId], references: [id])

  @@index([floorPlanId])
  @@map("floor_plan_zones")
}

enum FloorZoneType {
  UNIT
  COMMON_AREA
  TECHNICAL
  STORAGE
  PARKING
  OTHER
}

// ─── PAYMENT ORDERS (příkazy k úhradě) ──────────────────────────────────────

model PaymentOrder {
  id                 String             @id @default(uuid())
  tenantId           String
  bankAccountId      String
  financialContextId String
  createdById        String
  status             String             @default("draft") // draft | exported | cancelled
  exportFormat       String?            // pdf | abo
  exportedAt         DateTime?
  note               String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bankAccount        BankAccount        @relation(fields: [bankAccountId], references: [id])
  createdBy          User               @relation(fields: [createdById], references: [id])
  items              PaymentOrderItem[]

  @@index([tenantId])
  @@map("payment_orders")
}

model PaymentOrderItem {
  id                  String       @id @default(uuid())
  paymentOrderId      String
  counterpartyName    String?
  counterpartyAccount String
  counterpartyBankCode String
  amount              Decimal      @db.Decimal(12, 2)
  variableSymbol      String?
  specificSymbol      String?
  constantSymbol      String?
  description         String?
  invoiceId           String?
  prescriptionId      String?
  createdAt           DateTime     @default(now())

  paymentOrder        PaymentOrder @relation(fields: [paymentOrderId], references: [id], onDelete: Cascade)

  @@index([paymentOrderId])
  @@map("payment_order_items")
}

// ─── EVIDENCE FOLDERS (evidenční složky — náklady mimo vyúčtování) ───────────

model EvidenceFolder {
  id          String   @id @default(cuid())
  tenantId    String
  propertyId  String
  name        String
  code        String?
  description String?
  color       String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property    Property                  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  allocations EvidenceFolderAllocation[]

  @@index([tenantId, propertyId])
  @@map("evidence_folders")
}

model EvidenceFolderAllocation {
  id               String         @id @default(cuid())
  evidenceFolderId String
  invoiceId        String
  amount           Decimal        @db.Decimal(12, 2)
  year             Int?
  periodFrom       DateTime?
  periodTo         DateTime?
  note             String?
  createdAt        DateTime       @default(now())

  evidenceFolder   EvidenceFolder @relation(fields: [evidenceFolderId], references: [id], onDelete: Cascade)
  invoice          Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([evidenceFolderId])
  @@index([invoiceId])
  @@map("evidence_folder_allocations")
}

// ─── AI EXTRACTION LOG ──────────────────────────────────────────────

model AiExtractionLog {
  id            String   @id @default(cuid())
  tenantId      String
  invoiceId     String?
  model         String
  inputTokens   Int
  outputTokens  Int
  costUsd       Decimal  @db.Decimal(10, 6)
  confidence    String
  fileName      String?
  success       Boolean  @default(true)
  createdAt     DateTime @default(now())
  createdBy     String?

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("ai_extraction_logs")
}

model SupplierExtractionPattern {
  id              String    @id @default(cuid())
  tenantId        String
  supplierIco     String
  supplierName    String?

  fieldExamples   Json      // Record<string, string> — field→example value
  hints           String?   // correction notes for the AI prompt

  usageCount      Int       @default(0)
  successRate     Float?
  lastUsedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, supplierIco])
  @@index([tenantId])
  @@map("supplier_extraction_patterns")
}

model AiExtractionBatch {
  id                String    @id @default(cuid())
  tenantId          String
  anthropicBatchId  String?
  status            String    @default("pending")
  // pending → submitted → processing → completed → failed

  totalCount        Int       @default(0)
  processedCount    Int       @default(0)
  failedCount       Int       @default(0)

  totalCostUsd      Decimal?  @db.Decimal(10, 6)
  createdAt         DateTime  @default(now())
  submittedAt       DateTime?
  completedAt       DateTime?
  createdBy         String?

  items             AiExtractionBatchItem[]
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@map("ai_extraction_batches")
}

model AiExtractionBatchItem {
  id              String    @id @default(cuid())
  batchId         String
  customId        String
  fileName        String?
  pdfBase64       String    @db.Text
  status          String    @default("pending")
  // pending → completed → failed

  extractedData   Json?
  confidence      String?
  invoiceId       String?
  errorMessage    String?

  inputTokens     Int?
  outputTokens    Int?
  costUsd         Decimal?  @db.Decimal(10, 6)

  createdAt       DateTime  @default(now())
  completedAt     DateTime?

  batch           AiExtractionBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  invoice         Invoice?          @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([batchId])
  @@map("ai_extraction_batch_items")
}

model InvoiceTrainingSample {
  id            String    @id @default(cuid())
  tenantId      String
  dokladId      String?
  pdfHash       String
  fileRef       String?   // storage key (replaces imageBase64); null = legacy row
  imageBase64   String?   @db.Text  // deprecated: will be cleaned up by TTL cron
  extractedJson Json
  source        String    // "claude_vision" | "manual"
  confirmedAt   DateTime  @default(now())
  createdAt     DateTime  @default(now())
  expiresAt     DateTime? // TTL: null = no expiry; set to createdAt + retention days

  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, pdfHash])
  @@index([tenantId])
  @@index([expiresAt])
  @@map("invoice_training_samples")
}

model InvoiceComment {
  id           String   @id @default(cuid())
  tenantId     String
  invoiceId    String
  userId       String
  userName     String
  userInitials String
  body         String   @db.Text
  type         String   @default("note") // "note" | "log"
  createdAt    DateTime @default(now())

  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice  Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([invoiceId, createdAt])
  @@index([tenantId])
  @@map("invoice_comments")
}

// ═══════════════════════════════════════════════════
// CHATTER — generic communication log on any entity
// ═══════════════════════════════════════════════════

enum ChatMessageType {
  USER_MESSAGE
  SYSTEM_LOG
  EMAIL_INBOUND
  EMAIL_OUTBOUND
}

model ChatMessage {
  id           String          @id @default(cuid())
  tenantId     String
  entityType   String
  entityId     String
  type         ChatMessageType @default(USER_MESSAGE)
  body         String          @db.Text
  htmlBody     String?         @db.Text
  authorId     String?
  author       User?           @relation("ChatAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  emailFrom    String?
  emailTo      String?
  emailSubject String?
  emailMsgId   String?
  attachments  ChatAttachment[]
  mentions     ChatMention[]
  createdAt    DateTime        @default(now())

  @@index([tenantId, entityType, entityId])
  @@map("chat_messages")
}

model ChatAttachment {
  id         String      @id @default(cuid())
  messageId  String
  message    ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  fileName   String
  mimeType   String
  storageKey String
  sizeBytes  Int?
  createdAt  DateTime    @default(now())

  @@map("chat_attachments")
}

model ChatMention {
  id        String      @id @default(cuid())
  messageId String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation("ChatMentioned", fields: [userId], references: [id], onDelete: Cascade)

  @@map("chat_mentions")
}

// ═══════════════════════════════════════════════════
// ACTIVITY — structured tasks on any entity
// ═══════════════════════════════════════════════════

enum ActivityKind {
  EMAIL
  CALL
  MEETING
  TASK
  DOCUMENT_UPLOAD
  SIGN_REQUEST
  REMINDER
}

enum ActivityStatus {
  PLANNED
  DONE
  CANCELLED
  OVERDUE
}

model ActivityType {
  id            String       @id @default(cuid())
  tenantId      String
  name          String
  kind          ActivityKind
  defaultDays   Int?
  icon          String?
  color         String?
  activities    Activity[]
  createdAt     DateTime     @default(now())

  @@unique([tenantId, name])
  @@map("activity_types")
}

model Activity {
  id             String         @id @default(cuid())
  tenantId       String
  entityType     String
  entityId       String
  activityTypeId String
  activityType   ActivityType   @relation(fields: [activityTypeId], references: [id])
  title          String
  note           String?        @db.Text
  deadline       DateTime
  assignedToId   String
  assignedTo     User           @relation("ActivityAssigned", fields: [assignedToId], references: [id])
  status         ActivityStatus @default(PLANNED)
  doneAt         DateTime?
  doneById       String?
  doneBy         User?          @relation("ActivityDone", fields: [doneById], references: [id], onDelete: SetNull)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, assignedToId, status, deadline])
  @@map("activities")
}
