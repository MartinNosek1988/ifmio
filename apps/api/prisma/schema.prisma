  @@index([tenantId, date])
  @@map("finance_transactions")
}

enum TransactionType {
  income
  expense
  transfer
}

enum TransactionStatus {
  pending
  completed
  cancelled
}

model Invoice {
  id             String      @id @default(uuid())
  tenantId       String
  propertyId     String?
  number         String
  type           InvoiceType @default(received)
  supplierName   String?
  supplierIco    String?
  supplierDic    String?
  buyerName      String?
  buyerIco       String?
  buyerDic       String?
  description    String?
  amountBase     Decimal     @default(0) @db.Decimal(12, 2)
  vatRate        Int         @default(0)
  vatAmount      Decimal     @default(0) @db.Decimal(12, 2)
  amountTotal    Decimal     @default(0) @db.Decimal(12, 2)
  rounding       Decimal     @default(0) @db.Decimal(10, 2)
  currency       String      @default("CZK")
  issueDate      DateTime
  duzp           DateTime?
  dueDate        DateTime?
  paymentDate    DateTime?
  isPaid         Boolean     @default(false)
  paymentMethod  String?
  paidAmount     Decimal?    @db.Decimal(12, 2)
  variableSymbol   String?
  constantSymbol   String?
  specificSymbol   String?
  paymentIban      String?
  allocationStatus String    @default("unallocated") // unallocated | partial | allocated
  transactionId  String?
  supplierId     String?
  buyerId        String?
  lines          Json?
  isdocXml       String?     @db.Text
  pdfBase64      String?     @db.Text
  note           String?
  tags           String[]    @default([])
  deletedAt      DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Approval workflow
  approvalStatus  InvoiceApprovalStatus @default(draft)
  submittedAt     DateTime?
  submittedById   String?
  approvedAt      DateTime?
  approvedById    String?
  rejectedAt      DateTime?
  rejectedById    String?
  rejectionReason String?

  financialContextId String?

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property         Property?         @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  transaction      BankTransaction?  @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  supplier         Resident?         @relation("InvoiceSupplier", fields: [supplierId], references: [id], onDelete: SetNull)
  buyer            Resident?         @relation("InvoiceBuyer", fields: [buyerId], references: [id], onDelete: SetNull)
  submittedBy      User?             @relation("InvoiceSubmitter", fields: [submittedById], references: [id], onDelete: SetNull)
  approvedBy       User?             @relation("InvoiceApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  rejectedBy       User?             @relation("InvoiceRejecter", fields: [rejectedById], references: [id], onDelete: SetNull)
  financialContext FinancialContext?  @relation(fields: [financialContextId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([financialContextId])
  @@index([tenantId, type])
  @@index([tenantId, isPaid])
  @@index([tenantId, isPaid, dueDate])
  @@index([tenantId, approvalStatus])
  @@index([supplierId])
  @@index([buyerId])
  @@map("invoices")

  costAllocations          InvoiceCostAllocation[]
  evidenceAllocations      EvidenceFolderAllocation[]
  aiExtractionLogs         AiExtractionLog[]
  batchItems               AiExtractionBatchItem[]
  comments                 InvoiceComment[]
}

// ─── INVOICE COST ALLOCATION (D1 — propojení dokladu se složkami předpisu) ────

model InvoiceCostAllocation {
  id              String    @id @default(uuid())
  invoiceId       String
  componentId     String
  amount          Decimal   @db.Decimal(12, 2)
  vatRate         Decimal?  @db.Decimal(5, 2)
  vatAmount       Decimal?  @db.Decimal(12, 2)
