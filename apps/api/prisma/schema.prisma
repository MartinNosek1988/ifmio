// ─── PROTOCOLS & HANDOVER ─────────────────────────────────────────

enum ProtocolSourceType {
  helpdesk
  revision
  work_order
}

enum ProtocolType {
  work_report
  handover
  revision_report
  service_protocol
}

enum ProtocolStatus {
  draft
  completed
  confirmed
}

enum Satisfaction {
  satisfied
  partially_satisfied
  dissatisfied
  neutral
}

model Protocol {
  id           String             @id @default(uuid())
  tenantId     String
  propertyId   String?
  sourceType   ProtocolSourceType
  sourceId     String
  protocolType ProtocolType       @default(work_report)
  number       String
  status       ProtocolStatus     @default(draft)
  title        String?

  // Parties (JSON snapshots for PDF immutability)
  supplierSnapshot Json?
  customerSnapshot Json?

  // Request metadata
  requesterName   String?
  dispatcherName  String?
  resolverName    String?
  categoryLabel   String?
  activityLabel   String?
  spaceLabel      String?
  tenantUnitLabel String?
  description     String? @db.Text
  publicNote      String? @db.Text
  internalNote    String? @db.Text

  // Dates
  submittedAt DateTime?
  dueAt       DateTime?
  completedAt DateTime?

  // Transport
  transportKm          Float?
  transportMode        String?
  transportDescription String? @db.Text

  // Handover & quality
  handoverAt          DateTime?
  satisfaction        Satisfaction?
  satisfactionComment String?       @db.Text

  // Signatures
  supplierSignatureName String?
  customerSignatureName String?
  supplierSignedAt      DateTime?
  customerSignedAt      DateTime?

  // Generated / uploaded documents
  generatedPdfDocumentId String?
  signedDocumentId       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property         Property?      @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  generatedPdfDoc  Document?      @relation("ProtocolGeneratedPdf", fields: [generatedPdfDocumentId], references: [id], onDelete: SetNull)
  signedDoc        Document?      @relation("ProtocolSignedDoc", fields: [signedDocumentId], references: [id], onDelete: SetNull)
  lines            ProtocolLine[]

  @@index([tenantId])
  @@index([tenantId, sourceType, sourceId])
  @@index([tenantId, status])
  @@index([tenantId, propertyId])
  @@map("protocols")
}

model ProtocolLine {
  id          String   @id @default(uuid())
  protocolId  String
  lineType    String   @default("labor") // labor, material, transport, other
  name        String
  unit        String?
  quantity    Float    @default(1)
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  protocol Protocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  @@index([protocolId])
  @@map("protocol_lines")
}

