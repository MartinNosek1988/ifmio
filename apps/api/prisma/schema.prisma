  requesterUserId  String?
  dispatcherUserId String?
  deadline         DateTime?
  completedAt      DateTime?
  estimatedHours   Float?
  actualHours      Float?
  laborCost        Decimal?   @db.Decimal(12, 2)
  materialCost     Decimal?   @db.Decimal(12, 2)
  totalCost        Decimal?   @db.Decimal(12, 2)
  note             String?    @db.Text

