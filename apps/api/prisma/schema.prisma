generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── TENANT ──────────────────────────────────────────────────────

model Tenant {
  id            String     @id @default(uuid())
  name          String
  slug          String     @unique
  plan          TenantPlan @default(free)
  isActive      Boolean    @default(true)
  maxUsers      Int        @default(5)
  maxProperties Int        @default(3)
  trialEndsAt   DateTime?
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  users               User[]
  properties          Property[]
  residents           Resident[]
  transactions        FinanceTransaction[]
  auditLogs           AuditLog[]
  occupancies         Occupancy[]
  bankAccounts        BankAccount[]
  bankTransactions    BankTransaction[]
  billingPeriods      BillingPeriod[]
  prescriptions       Prescription[]
  reminderTemplates   ReminderTemplate[]
  reminders           Reminder[]
  helpdeskTickets     HelpdeskTicket[]
  documents           Document[]
  settings            TenantSettings?
  importLogs          ImportLog[]
  notifications       Notification[]
  leaseAgreements     LeaseAgreement[]
  workOrders          WorkOrder[]
  meters              Meter[]
  calendarEvents      CalendarEvent[]
  assets              Asset[]
  assetServiceRecords AssetServiceRecord[]
  invoices            Invoice[]
  slaPolicies         SlaPolicy[]
  revisionSubjects    RevisionSubject[]
  revisionTypes       RevisionType[]
  revisionPlans       RevisionPlan[]
  revisionEvents      RevisionEvent[]
  protocols           Protocol[]
  assetTypes          AssetType[]
  assetTypeRevisionTypes AssetTypeRevisionType[]
  assetQrCodes        AssetQrCode[]
  assetQrScanEvents   AssetQrScanEvent[]
  fieldCheckExecutions AssetFieldCheckExecution[]
  reportSubscriptions  ScheduledReportSubscription[]
  recurringPlans       RecurringActivityPlan[]

  @@map("tenants")
}

enum TenantPlan {
  free
  starter
  pro
  enterprise
}

// ─── USER ─────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  tenantId     String
  email        String
  passwordHash String
  name         String
  role         UserRole  @default(viewer)
  isActive     Boolean   @default(true)
  phone        String?
  position     String?
  avatarBase64 String?
  language     String    @default("cs")
  timezone     String    @default("Europe/Prague")
  dateFormat   String    @default("DD.MM.YYYY")
  notifEmail   Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant                  Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refreshTokens           RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]
  auditLogs               AuditLog[]
  assignedTickets         HelpdeskTicket[]  @relation("TicketAssignee")
  requestedTickets        HelpdeskTicket[]  @relation("TicketRequester")
  dispatchedTickets       HelpdeskTicket[]  @relation("TicketDispatcher")
  createdDocuments        Document[]
  notifications           Notification[]
  propertyAssignments     UserPropertyAssignment[]
  submittedInvoices       Invoice[]                @relation("InvoiceSubmitter")
  approvedInvoices        Invoice[]                @relation("InvoiceApprover")
  rejectedInvoices        Invoice[]                @relation("InvoiceRejecter")
  responsiblePlans        RevisionPlan[]
  qrScanEvents            AssetQrScanEvent[]
  fieldCheckExecutions    AssetFieldCheckExecution[]
  assignedWorkOrders      WorkOrder[]               @relation("WOAssignee")
  requestedWorkOrders     WorkOrder[]               @relation("WORequester")
  dispatchedWorkOrders    WorkOrder[]               @relation("WODispatcher")
  reportSubscriptions     ScheduledReportSubscription[]
  assignedRecurringPlans  RecurringActivityPlan[]       @relation("RecurringPlanAssignee")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

enum UserRole {
  tenant_owner
  tenant_admin
  property_manager
  finance_manager
  operations
  viewer
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

// ─── AUDIT LOG ────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String?
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldData   Json?
  newData   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, entity])
  @@index([tenantId, createdAt])
  @@index([tenantId, entity, action])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

// ─── PROPERTY ─────────────────────────────────────────────────────

model Property {
  id         String         @id @default(uuid())
  tenantId   String
  name       String
  address    String
  city       String
  postalCode String
  type       PropertyType
  ownership  OwnershipType
  status     PropertyStatus @default(active)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  units           Unit[]
  residents       Resident[]
  bankAccounts    BankAccount[]
  billingPeriods  BillingPeriod[]
  prescriptions   Prescription[]
  helpdeskTickets HelpdeskTicket[]
  leaseAgreements LeaseAgreement[]
  workOrders      WorkOrder[]
  meters          Meter[]
  assets          Asset[]
  invoices        Invoice[]
  protocols       Protocol[]

  userAssignments  UserPropertyAssignment[]
  slaPolicies      SlaPolicy[]
  revisionSubjects RevisionSubject[]
  revisionPlans    RevisionPlan[]
  revisionEvents        RevisionEvent[]
  reportSubscriptions   ScheduledReportSubscription[]
  recurringPlans        RecurringActivityPlan[]

  @@index([tenantId])
  @@map("properties")
}

// ─── USER ↔ PROPERTY ASSIGNMENT ─────────────────────────────────

model UserPropertyAssignment {
  id         String   @id @default(uuid())
  userId     String
  propertyId String
  assignedBy String?
  assignedAt DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
  @@map("user_property_assignments")
}

enum PropertyType {
  bytdum
  roddum
  komer
  prumysl
  pozemek
  garaz
}

enum OwnershipType {
  vlastnictvi
  druzstvo
  pronajem
}

enum PropertyStatus {
  active
  inactive
  archived
}

model Unit {
  id         String   @id @default(uuid())
  propertyId String
  name       String
  floor      Int?
  area       Float?
  isOccupied Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property        Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  residents       Resident[]
  occupancies     Occupancy[]
  prescriptions   Prescription[]
  helpdeskTickets HelpdeskTicket[]
  leaseAgreements LeaseAgreement[]
  workOrders      WorkOrder[]
  meters          Meter[]
  assets          Asset[]

  @@index([propertyId])
  @@map("units")
}

// ─── RESIDENT ─────────────────────────────────────────────────────

model Resident {
  id         String       @id @default(uuid())
  tenantId   String
  propertyId String?
  unitId     String?
  firstName  String
  lastName   String
  email      String?
  phone      String?
  role       ResidentRole
  isActive   Boolean      @default(true)
  hasDebt    Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property         Property?         @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  unit             Unit?             @relation(fields: [unitId], references: [id], onDelete: SetNull)
  occupancies      Occupancy[]
  prescriptions    Prescription[]
  bankTransactions BankTransaction[]
  reminders        Reminder[]
  helpdeskTickets  HelpdeskTicket[]
  leaseAgreements  LeaseAgreement[]
  supplierInvoices Invoice[]         @relation("InvoiceSupplier")
  buyerInvoices    Invoice[]         @relation("InvoiceBuyer")

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([propertyId, isActive])
  @@index([tenantId, hasDebt])
  @@map("residents")
}

enum ResidentRole {
  owner
  tenant
  member
  contact
}

// ─── OCCUPANCY ────────────────────────────────────────────────────

model Occupancy {
  id         String        @id @default(uuid())
  tenantId   String
  unitId     String
  residentId String
  role       OccupancyRole
  startDate  DateTime
  endDate    DateTime?
  isActive   Boolean       @default(true)
  note       String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unit     Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  resident Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([unitId])
  @@index([residentId])
  @@map("occupancies")
}

enum OccupancyRole {
  owner
  tenant
  member
}

// ─── FINANCE ──────────────────────────────────────────────────────

model FinanceTransaction {
  id          String            @id @default(uuid())
  tenantId    String
  propertyId  String?
  type        TransactionType
  status      TransactionStatus @default(pending)
  amount      Decimal           @db.Decimal(12, 2)
  vatRate     Int               @default(0)
  vatAmount   Decimal           @default(0) @db.Decimal(12, 2)
  description String
  date        DateTime
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, date])
  @@map("finance_transactions")
}

enum TransactionType {
  income
  expense
  transfer
}

enum TransactionStatus {
  pending
  completed
  cancelled
}

model Invoice {
  id             String      @id @default(uuid())
  tenantId       String
  propertyId     String?
  number         String
  type           InvoiceType @default(received)
  supplierName   String?
  supplierIco    String?
  supplierDic    String?
  buyerName      String?
  buyerIco       String?
  buyerDic       String?
  description    String?
  amountBase     Decimal     @default(0) @db.Decimal(12, 2)
  vatRate        Int         @default(0)
  vatAmount      Decimal     @default(0) @db.Decimal(12, 2)
  amountTotal    Decimal     @default(0) @db.Decimal(12, 2)
  currency       String      @default("CZK")
  issueDate      DateTime
  duzp           DateTime?
  dueDate        DateTime?
  paymentDate    DateTime?
  isPaid         Boolean     @default(false)
  paymentMethod  String?
  paidAmount     Decimal?    @db.Decimal(12, 2)
  variableSymbol String?
  transactionId  String?
  supplierId     String?
  buyerId        String?
  lines          Json?
  isdocXml       String?     @db.Text
  note           String?
  deletedAt      DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Approval workflow
  approvalStatus  InvoiceApprovalStatus @default(draft)
  submittedAt     DateTime?
  submittedById   String?
  approvedAt      DateTime?
  approvedById    String?
  rejectedAt      DateTime?
  rejectedById    String?
  rejectionReason String?

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property    Property?        @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  transaction BankTransaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  supplier    Resident?        @relation("InvoiceSupplier", fields: [supplierId], references: [id], onDelete: SetNull)
  buyer       Resident?        @relation("InvoiceBuyer", fields: [buyerId], references: [id], onDelete: SetNull)
  submittedBy User?            @relation("InvoiceSubmitter", fields: [submittedById], references: [id], onDelete: SetNull)
  approvedBy  User?            @relation("InvoiceApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  rejectedBy  User?            @relation("InvoiceRejecter", fields: [rejectedById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, isPaid])
  @@index([tenantId, isPaid, dueDate])
  @@index([tenantId, approvalStatus])
  @@index([supplierId])
  @@index([buyerId])
  @@map("invoices")
}

enum InvoiceType {
  received
  issued
  proforma
  credit_note
}

enum InvoiceApprovalStatus {
  draft
  submitted
  approved
}

// ─── FINANCE ROZŠÍŘENÍ ────────────────────────────────────────────

model BankAccount {
  id            String   @id @default(uuid())
  tenantId      String
  propertyId    String?
  name          String
  accountNumber String
  iban          String?
  bankCode      String?
  currency      String   @default("CZK")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property     Property?         @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  transactions BankTransaction[]
  importLogs   ImportLog[]

  @@index([tenantId])
  @@map("bank_accounts")
}

model BankTransaction {
  id               String                @id @default(uuid())
  tenantId         String
  bankAccountId    String
  amount           Decimal               @db.Decimal(12, 2)
  type             BankTransactionType
  status           BankTransactionStatus @default(unmatched)
  date             DateTime
  counterparty     String?
  counterpartyIban String?
  variableSymbol   String?
  specificSymbol   String?
  constantSymbol   String?
  description      String?
  prescriptionId   String?
  residentId       String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bankAccount  BankAccount   @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)
  prescription Prescription? @relation(fields: [prescriptionId], references: [id], onDelete: SetNull)
  resident     Resident?     @relation(fields: [residentId], references: [id], onDelete: SetNull)
  invoices     Invoice[]

  @@index([tenantId])
  @@index([tenantId, date])
  @@index([tenantId, status])
  @@index([tenantId, status, date])
  @@index([tenantId, bankAccountId, date, amount, variableSymbol])
  @@index([bankAccountId, date])
  @@index([variableSymbol])
  @@map("bank_transactions")
}

enum BankTransactionType {
  credit
  debit
}

enum BankTransactionStatus {
  unmatched
  matched
  partially_matched
}

model BillingPeriod {
  id         String              @id @default(uuid())
  tenantId   String
  propertyId String
  name       String
  dateFrom   DateTime
  dateTo     DateTime
  status     BillingPeriodStatus @default(open)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property      Property       @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  prescriptions Prescription[]

  @@index([tenantId])
  @@index([propertyId])
  @@map("billing_periods")
}

enum BillingPeriodStatus {
  open
  closed
  settled
}

model Prescription {
  id              String             @id @default(uuid())
  tenantId        String
  propertyId      String
  unitId          String?
  residentId      String?
  billingPeriodId String?
  type            PrescriptionType
  status          PrescriptionStatus @default(active)
  amount          Decimal            @db.Decimal(12, 2)
  vatRate         Int                @default(0)
  vatAmount       Decimal            @default(0) @db.Decimal(12, 2)
  dueDay          Int                @default(15)
  variableSymbol  String?
  description     String
  validFrom       DateTime
  validTo         DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property      Property           @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  unit          Unit?              @relation(fields: [unitId], references: [id], onDelete: SetNull)
  resident      Resident?          @relation(fields: [residentId], references: [id], onDelete: SetNull)
  billingPeriod BillingPeriod?     @relation(fields: [billingPeriodId], references: [id], onDelete: SetNull)
  items         PrescriptionItem[]
  transactions  BankTransaction[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([propertyId])
  @@index([residentId, status])
  @@index([variableSymbol])
  @@map("prescriptions")
}

enum PrescriptionType {
  advance
  service
  rent
  other
}

enum PrescriptionStatus {
  active
  inactive
  cancelled
}

model PrescriptionItem {
  id             String   @id @default(uuid())
  prescriptionId String
  name           String
  amount         Decimal  @db.Decimal(12, 2)
  vatRate        Int      @default(0)
  unit           String?
  quantity       Decimal  @default(1) @db.Decimal(10, 3)
  createdAt      DateTime @default(now())

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@index([prescriptionId])
  @@map("prescription_items")
}

// ─── REMINDERS ────────────────────────────────────────────────────

model ReminderTemplate {
  id        String        @id @default(uuid())
  tenantId  String
  name      String
  level     ReminderLevel
  subject   String
  body      String        @db.Text
  dueDays   Int           @default(14)
  isDefault Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reminders Reminder[]

  @@index([tenantId])
  @@map("reminder_templates")
}

enum ReminderLevel {
  first
  second
  third
}

model Reminder {
  id         String         @id @default(uuid())
  tenantId   String
  residentId String
  templateId String?
  level      ReminderLevel
  status     ReminderStatus @default(draft)
  amount     Decimal        @db.Decimal(12, 2)
  dueDate    DateTime
  sentAt     DateTime?
  note       String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  resident Resident          @relation(fields: [residentId], references: [id], onDelete: Restrict)
  template ReminderTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, status, level])
  @@index([tenantId, dueDate])
  @@index([residentId])
  @@index([residentId, status])
  @@map("reminders")
}

enum ReminderStatus {
  draft
  sent
  paid
  escalated
}

// ─── RECURRING ACTIVITY PLANS ─────────────────────────────────────

model RecurringActivityPlan {
  id               String   @id @default(uuid())
  tenantId         String
  propertyId       String?
  assetId          String?
  title            String
  description      String?  @db.Text
  category         String   @default("maintenance") // maintenance, inspection, reading, revision
  scheduleMode     String   @default("calendar")    // calendar | from_completion
  frequencyUnit    String   @default("day")          // day | week | month | year
  frequencyInterval Int     @default(1)
  dayOfWeek        Int?     // 0=Sun..6=Sat for weekly
  dayOfMonth       Int?     // 1-31 for monthly
  monthOfYear      Int?     // 1-12 for yearly
  leadDays         Int      @default(0)
  priority         String   @default("medium")       // low | medium | high | urgent
  assigneeUserId   String?
  isActive         Boolean  @default(true)
  lastCompletedAt  DateTime?
  nextPlannedAt    DateTime?
  lastGeneratedAt  DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  asset    Asset?    @relation(fields: [assetId], references: [id], onDelete: SetNull)
  assignee User?     @relation("RecurringPlanAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  generatedTickets HelpdeskTicket[]

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([assetId])
  @@index([tenantId, isActive, nextPlannedAt])
  @@map("recurring_activity_plans")
}

// ─── HELPDESK ─────────────────────────────────────────────────────

model HelpdeskTicket {
  id          String         @id @default(uuid())
  tenantId    String
  propertyId  String?
  unitId      String?
  residentId  String?
  assetId     String?
  number      Int
  title       String
  description String?        @db.Text
  category    TicketCategory @default(general)
  priority    TicketPriority @default(medium)
  status      TicketStatus   @default(open)
  assigneeId  String?
  requesterUserId  String?
  dispatcherUserId String?
  resolvedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // SLA fields
  responseDueAt      DateTime?
  resolutionDueAt    DateTime?
  deadlineManuallySet Boolean  @default(false)
  firstResponseAt    DateTime?
  escalationLevel    Int       @default(0)
  escalatedAt        DateTime?

  // Recurring generation tracking
  recurringPlanId    String?
  generationKey      String?   @unique
  plannedForDate     DateTime?
  requestOrigin      String?   // 'manual' | 'recurring_plan' | 'revision'

  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property  Property?         @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  unit      Unit?             @relation(fields: [unitId], references: [id], onDelete: SetNull)
  resident  Resident?         @relation(fields: [residentId], references: [id], onDelete: SetNull)
  asset     Asset?            @relation(fields: [assetId], references: [id], onDelete: SetNull)
  assignee  User?             @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  requester User?             @relation("TicketRequester", fields: [requesterUserId], references: [id], onDelete: SetNull)
  dispatcher User?            @relation("TicketDispatcher", fields: [dispatcherUserId], references: [id], onDelete: SetNull)
  recurringPlan RecurringActivityPlan? @relation(fields: [recurringPlanId], references: [id], onDelete: SetNull)
  items      HelpdeskItem[]
  protocol   HelpdeskProtocol?
  workOrders WorkOrder[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, status, createdAt])
  @@index([propertyId, status])
  @@index([tenantId, resolutionDueAt])
  @@index([assetId])
  @@index([recurringPlanId])
  @@map("helpdesk_tickets")
}

enum TicketCategory {
  general
  plumbing
  electrical
  hvac
  structural
  cleaning
  other
}

enum TicketPriority {
  low
  medium
  high
  urgent
}

enum TicketStatus {
  open
  in_progress
  resolved
  closed
}

model HelpdeskItem {
  id          String   @id @default(uuid())
  ticketId    String
  description String
  unit        String?
  quantity    Decimal  @default(1) @db.Decimal(10, 3)
  unitPrice   Decimal  @default(0) @db.Decimal(12, 2)
  totalPrice  Decimal  @default(0) @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  ticket HelpdeskTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("helpdesk_items")
}

model HelpdeskProtocol {
  id           String    @id @default(uuid())
  ticketId     String    @unique
  number       String
  workerName   String?
  workerDate   DateTime?
  clientName   String?
  clientSigned Boolean   @default(false)
  note         String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

