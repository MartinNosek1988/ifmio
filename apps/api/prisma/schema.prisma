enum KontoReminderStatus {
  DRAFT
  SENT
  ACKNOWLEDGED
  RESOLVED
  CANCELLED
}

enum KontoReminderMethod {
  EMAIL
  DATABOX
  POST
  IN_PERSON
}

// ─── REMINDERS ────────────────────────────────────────────────────

model ReminderTemplate {
