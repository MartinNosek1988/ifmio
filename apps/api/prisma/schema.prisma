  invoice       Invoice               @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  component     PrescriptionComponent @relation(fields: [componentId], references: [id])

  @@index([invoiceId])
  @@index([componentId])
  @@map("invoice_cost_allocations")
}

// ─── ACCOUNTING PRESETS (D1 — předkontace) ───────────────────────────

model AccountingPreset {
  id              String   @id @default(uuid())
  tenantId        String
  propertyId      String?
  name            String
  transactionType String              // prescription | payment | invoice_received | invoice_issued
  debitAccount    String              // MD účet
  creditAccount   String              // DAL účet
  componentId     String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("accounting_presets")
}

enum InvoiceType {
  received
  issued
  proforma
  credit_note
  internal      // interní doklad
}

enum InvoiceApprovalStatus {
  draft
  submitted
  approved
}

// ─── FINANCE ROZŠÍŘENÍ ────────────────────────────────────────────

model BankAccount {
  id            String           @id @default(uuid())
  tenantId      String
  propertyId    String?
  name          String
  accountNumber String
  iban          String?
  bankCode      String?
  currency      String           @default("CZK")
  isActive      Boolean          @default(true)
  isDefault     Boolean          @default(false)
  accountType   BankAccountType?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  // Banking API sync fields
  bankProvider      String?          @db.VarChar(20)   // "fio", "kb", "csob", "manual"
  apiToken          String?          @db.Text           // API token (Fio: read-only token)
  apiTokenLastFour  String?          @db.VarChar(4)     // For display: "****3456"
  syncEnabled       Boolean          @default(false)
  syncIntervalMin   Int              @default(60)       // Polling interval in minutes
  lastSyncAt        DateTime?
  lastSyncCursor    String?                              // Last transaction ID for incremental fetch
  syncStatus        String?          @db.VarChar(20)    // "active", "error", "disabled"
  syncStatusMessage String?                              // Error detail if syncStatus = "error"

  financialContextId String

  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property         Property?        @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  financialContext FinancialContext  @relation(fields: [financialContextId], references: [id], onDelete: Restrict)
  transactions     BankTransaction[]
  importLogs       ImportLog[]
  paymentOrders    PaymentOrder[]

  @@index([tenantId])
  @@index([financialContextId])
  @@map("bank_accounts")
}

enum BankAccountType {
  OPERATING
  REPAIR_FUND
  SAVINGS
  OTHER
}

model BankTransaction {
  id                   String                @id @default(uuid())
  tenantId             String
  bankAccountId        String
  amount               Decimal               @db.Decimal(12, 2)
  type                 BankTransactionType
  status               BankTransactionStatus @default(unmatched)
  date                 DateTime
  bookingDate          DateTime?             // datum zaúčtování (pokud se liší od data pohybu)
  counterparty         String?
  counterpartyIban     String?
  counterpartyAccount  String?               // číslo účtu protistrany (CZ formát)
  counterpartyBankCode String?               // kód banky protistrany
  variableSymbol       String?
  specificSymbol       String?
  constantSymbol       String?
  description          String?
  messageForRecipient  String?               // zpráva pro příjemce
  prescriptionId       String?
  residentId           String?
  externalId           String?               // ID z bankovního API pro deduplikaci
  importSource         String?               // 'csv', 'abo', 'fio_api' — odkud transakce přišla
  rawData              Json?                 // surová data z API/importu

  // Enhanced matching fields
  matchTarget          MatchTarget?          // target type for the match
  matchedEntityId      String?               // ID of matched entity (prescription/invoice/component)
  matchedEntityType    String?               // 'prescription' | 'invoice' | 'component'
  matchedAt            DateTime?             // when matched
  matchedBy            String?               // 'auto' | 'manual' | userId
  matchNote            String?               // optional note on match
  splitParentId        String?               // for split transactions (partial payments)

  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  financialContextId String?

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bankAccount      BankAccount       @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)
  prescription     Prescription?     @relation(fields: [prescriptionId], references: [id], onDelete: SetNull)
  resident         Resident?         @relation(fields: [residentId], references: [id], onDelete: SetNull)
  financialContext FinancialContext?  @relation(fields: [financialContextId], references: [id], onDelete: SetNull)
  invoices         Invoice[]
  splitParent      BankTransaction?  @relation("SplitTransactions", fields: [splitParentId], references: [id], onDelete: SetNull)
  splitChildren    BankTransaction[] @relation("SplitTransactions")
  ledgerEntryId    String?           @unique // link to auto-posted LedgerEntry

  @@unique([bankAccountId, externalId])
  @@index([tenantId])
  @@index([financialContextId])
  @@index([tenantId, date])
  @@index([tenantId, status])
  @@index([tenantId, status, date])
  @@index([tenantId, bankAccountId, date, amount, variableSymbol])
  @@index([bankAccountId, date])
  @@index([variableSymbol])
  @@index([splitParentId])
  @@map("bank_transactions")
}

enum BankTransactionType {
  credit
  debit
}

enum BankTransactionStatus {
  unmatched
  matched
  partially_matched
  ignored
}

enum MatchTarget {
  KONTO          // → credits resident's konto account (most common for SVJ)
  INVOICE        // → pairs with specific invoice (doklad)
  COMPONENT      // → allocates to specific prescription component (složka)
  NO_EFFECT      // → recorded but no financial effect (bank fees, interest, internal transfers)
  UNSPECIFIED    // → imported but not yet classified
}

model BillingPeriod {
  id         String              @id @default(uuid())
  tenantId   String
  propertyId String
  name       String
  dateFrom   DateTime
  dateTo     DateTime
  status     BillingPeriodStatus @default(open)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property      Property       @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  prescriptions Prescription[]
  settlements   Settlement[]

  @@index([tenantId])
  @@index([propertyId])
  @@map("billing_periods")
}

enum BillingPeriodStatus {
  open
  closed
  settled
}

model Prescription {
  id              String             @id @default(uuid())
  tenantId        String
  propertyId      String
  unitId          String?
  residentId      String?
  billingPeriodId String?
  type            PrescriptionType
  status          PrescriptionStatus @default(active)
  amount          Decimal            @db.Decimal(12, 2)
  vatRate         Int                @default(0)
  vatAmount       Decimal            @default(0) @db.Decimal(12, 2)
  dueDay          Int                @default(15)
  variableSymbol  String?
  description     String
  source          String?            // 'COMPONENTS' | 'MANUAL' | 'CALC' — jak předpis vznikl
  validFrom       DateTime
  validTo         DateTime?

  // Payment tracking
  paidAmount      Decimal?           @default(0) @db.Decimal(12, 2)
  paidAt          DateTime?
  paymentStatus   PaymentStatus      @default(UNPAID)

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  financialContextId String?

  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property         Property           @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  unit             Unit?              @relation(fields: [unitId], references: [id], onDelete: SetNull)
  resident         Resident?          @relation(fields: [residentId], references: [id], onDelete: SetNull)
  billingPeriod    BillingPeriod?     @relation(fields: [billingPeriodId], references: [id], onDelete: SetNull)
  financialContext FinancialContext?  @relation(fields: [financialContextId], references: [id], onDelete: SetNull)
  items            PrescriptionItem[]
  transactions     BankTransaction[]
  ledgerEntryId    String?            @unique // link to auto-posted LedgerEntry

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([propertyId])
  @@index([residentId, status])
  @@index([variableSymbol])
  @@index([financialContextId])
  @@map("prescriptions")
}

enum PrescriptionType {
  advance
  service
  rent
  other
}

enum PrescriptionStatus {
  active
  inactive
  cancelled
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  OVERPAID
}

model PrescriptionItem {
  id             String   @id @default(uuid())
  prescriptionId String
  componentId    String?                // FK zpět na složku, ze které řádek vznikl
  name           String
  amount         Decimal  @db.Decimal(12, 2)
  vatRate        Int      @default(0)
  unit           String?
  quantity       Decimal  @default(1) @db.Decimal(10, 3)
  createdAt      DateTime @default(now())

  prescription Prescription            @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  component    PrescriptionComponent?  @relation(fields: [componentId], references: [id])

  @@index([prescriptionId])
  @@map("prescription_items")
}

// ─── PRESCRIPTION COMPONENTS (Složky předpisu) ───────────────────

enum ComponentType {
  ADVANCE       // záloha — vyúčtovatelná
  FLAT_FEE      // paušál — bez vyúčtování
  FUND          // fond oprav — kumulativní
  RENT          // nájem
  DEPOSIT       // kauce
  ANNUITY       // anuita / splátka úvěru
  ACCESSORY     // příslušenství — úroky a poplatky z prodlení
  OTHER         // ostatní
}

enum RatePeriod {
  MONTHLY
  QUARTERLY
  YEARLY
  CUSTOM
}

enum CalculationMethod {
  FIXED            // pevná částka per jednotka
  PER_AREA         // sazba × podlahová plocha m²
  PER_HEATING_AREA // sazba × vytápěná plocha m²
  PER_PERSON       // sazba × počet osob
  PER_SHARE        // sazba × podíl na společných částech
  MANUAL           // ruční nastavení per jednotka
}

enum AllocationMethod {
  area             // dle podlahové plochy
  share            // dle podílu na společných částech
  persons          // dle počtu osob
  consumption      // dle měřidel (spotřeba)
  equal            // rovným dílem
  heating_area     // dle plochy pro vytápění
  custom           // ruční
}

model PrescriptionComponent {
  id                String              @id @default(cuid())
  tenantId          String
  propertyId        String
  name              String
  code              String?
  componentType     ComponentType
  calculationMethod CalculationMethod
  allocationMethod  AllocationMethod    @default(area)  // Rozúčtování nákladů pro vyúčtování
  defaultAmount     Decimal             @db.Decimal(12, 2)
  vatRate           Int                 @default(0)
  description       String?
  accountingCode    String?
  sortOrder         Int                 @default(0)
  isActive          Boolean             @default(true)
  effectiveFrom     DateTime
  effectiveTo       DateTime?
  // Domsys alignment fields
  initialBalance       Decimal?         @db.Decimal(14, 2)  // počáteční stav fondu (FUND/DEPOSIT)
  includeInSettlement  Boolean          @default(true)       // vyúčtovat (ADVANCE/FUND=true, ostatní=false)
  minimumPayment       Decimal?         @db.Decimal(12, 2)   // minimální výše platby
  ratePeriod           RatePeriod       @default(MONTHLY)    // perioda předpisu
  ratePeriodMonths     Int[]                                 // pro CUSTOM — čísla měsíců [1,3,6,9,12]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  property          Property            @relation(fields: [propertyId], references: [id])
  assignments       ComponentAssignment[]
  prescriptionItems  PrescriptionItem[]
  costAllocations    InvoiceCostAllocation[]

  @@index([tenantId, propertyId])
  @@index([tenantId, propertyId, isActive])
  @@map("prescription_components")
}

model ComponentAssignment {
  id              String                @id @default(cuid())
  tenantId        String
  componentId     String
  unitId          String
  overrideAmount  Decimal?              @db.Decimal(12, 2)
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  isActive        Boolean               @default(true)
  note            String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  component       PrescriptionComponent @relation(fields: [componentId], references: [id])
  unit            Unit                  @relation(fields: [unitId], references: [id])

  @@unique([componentId, unitId, effectiveFrom])
  @@index([tenantId, componentId])
  @@index([unitId])
  @@map("component_assignments")
}

// ─── KONTO (Owner Account / Ledger) ──────────────────────────────

model OwnerAccount {
  id             String       @id @default(cuid())
  tenantId       String
  propertyId     String
  unitId         String
  residentId     String
  currentBalance     Decimal      @default(0) @db.Decimal(12, 2)
  lastPostingAt      DateTime?
  openingBalanceSet  Boolean      @default(false)
  openingBalanceDate DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  property Property @relation(fields: [propertyId], references: [id])
  unit     Unit     @relation(fields: [unitId], references: [id])
  resident Resident @relation(fields: [residentId], references: [id])
  entries   LedgerEntry[]
  reminders KontoReminder[]

  @@unique([tenantId, unitId, residentId])
  @@index([tenantId, propertyId])
  @@map("owner_accounts")
}

model LedgerEntry {
  id          String           @id @default(cuid())
  accountId   String
  type        LedgerEntryType
  amount      Decimal          @db.Decimal(12, 2)
  balance     Decimal          @db.Decimal(12, 2) // running balance AFTER this entry
  sourceType  LedgerSourceType
  sourceId    String
  description String?
  postingDate DateTime         @default(now())
  createdAt   DateTime         @default(now())

  account OwnerAccount @relation(fields: [accountId], references: [id])

  @@index([accountId, postingDate])
  @@index([sourceType, sourceId])
  @@map("ledger_entries")
}

enum LedgerEntryType {
  DEBIT
  CREDIT
  ADJUSTMENT
}

enum LedgerSourceType {
  PRESCRIPTION
  BANK_TRANSACTION
  CREDIT_APPLICATION
  LATE_FEE
  MANUAL_ADJUSTMENT
  OPENING_BALANCE
  SETTLEMENT
  SIPO
}

// ─── INITIAL BALANCES (Počáteční stavy) ──────────────────────────

model InitialBalance {
  id             String              @id @default(cuid())
  tenantId       String
  propertyId     String
  type           InitialBalanceType
  entityId       String?             // unitId, residentId, bankAccountId, meterId, componentId
  entityType     String?             // 'unit', 'resident', 'bankAccount', 'meter', 'fund'
  amount         Decimal             @db.Decimal(12, 2)
  meterValue     Decimal?            @db.Decimal(12, 3)  // for meter readings
  cutoverDate    DateTime            // datum přechodu
  note           String?
  createdBy      String?             // userId
  postedToKonto  Boolean             @default(false)
  ledgerEntryId  String?             // FK to LedgerEntry for konto posting audit
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  property       Property            @relation(fields: [propertyId], references: [id])

  @@unique([tenantId, propertyId, type, entityId])
  @@index([tenantId, propertyId])
  @@index([tenantId, type])
  @@map("initial_balances")
}

enum InitialBalanceType {
  OWNER_DEBT          // dluh vlastníka/nájemce
  OWNER_OVERPAYMENT   // přeplatek vlastníka
  BANK_ACCOUNT        // počáteční zůstatek bankovního účtu
  FUND_BALANCE        // zůstatek fondu (fond oprav, fond údržby)
  DEPOSIT             // kauce
  METER_READING       // počáteční stav měřidla
}

// ─── KONTO REMINDERS (Wave 2) ─────────────────────────────────────

model KontoReminder {
  id              String               @id @default(cuid())
  tenantId        String
  propertyId      String
  accountId       String
  residentId      String
  unitId          String
  reminderNumber  Int                  // 1st, 2nd, 3rd
