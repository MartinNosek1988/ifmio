generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── TENANT ──────────────────────────────────────────────────────

model Tenant {
  id            String      @id @default(uuid())
  name          String
  slug          String      @unique
  plan          TenantPlan  @default(free)
  isActive      Boolean     @default(true)
  maxUsers      Int         @default(5)
  maxProperties Int         @default(3)
  trialEndsAt   DateTime?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  users            User[]
  properties       Property[]
  residents        Resident[]
  transactions     FinanceTransaction[]
  auditLogs        AuditLog[]
  occupancies      Occupancy[]
  bankAccounts      BankAccount[]
  bankTransactions  BankTransaction[]
  billingPeriods    BillingPeriod[]
  prescriptions     Prescription[]
  reminderTemplates ReminderTemplate[]
  reminders         Reminder[]
  helpdeskTickets   HelpdeskTicket[]
  documents         Document[]
  settings          TenantSettings?
  importLogs        ImportLog[]
  notifications     Notification[]
  leaseAgreements   LeaseAgreement[]
  workOrders        WorkOrder[]
  meters              Meter[]
  calendarEvents      CalendarEvent[]
  assets              Asset[]
  assetServiceRecords AssetServiceRecord[]

  @@map("tenants")
}

enum TenantPlan {
  free
  starter
  pro
  enterprise
}

// ─── USER ─────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  tenantId     String
  email        String
  passwordHash String
  name         String
  role         UserRole  @default(viewer)
  isActive     Boolean   @default(true)
  phone        String?
  position     String?
  avatarBase64 String?
  language     String    @default("cs")
  timezone     String    @default("Europe/Prague")
  dateFormat   String    @default("DD.MM.YYYY")
  notifEmail   Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refreshTokens    RefreshToken[]
  auditLogs        AuditLog[]
  assignedTickets  HelpdeskTicket[]
  createdDocuments Document[]
  notifications    Notification[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

enum UserRole {
  owner
  admin
  manager
  technician
  viewer
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─── AUDIT LOG ────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String?
  action     String
  entity     String
  entityId   String?
  oldData    Json?
  newData    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, entity])
  @@index([tenantId, createdAt])
  @@index([tenantId, entity, action])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

// ─── PROPERTY ─────────────────────────────────────────────────────

model Property {
  id         String         @id @default(uuid())
  tenantId   String
  name       String
  address    String
  city       String
  postalCode String
  type       PropertyType
  ownership  OwnershipType
  status     PropertyStatus @default(active)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  units           Unit[]
  residents       Resident[]
  bankAccounts    BankAccount[]
  billingPeriods  BillingPeriod[]
  prescriptions   Prescription[]
  helpdeskTickets HelpdeskTicket[]
  leaseAgreements LeaseAgreement[]
  workOrders      WorkOrder[]
  meters          Meter[]
  assets          Asset[]

  @@index([tenantId])
  @@map("properties")
}

enum PropertyType {
  bytdum
  roddum
  komer
  prumysl
  pozemek
  garaz
}

enum OwnershipType {
  vlastnictvi
  druzstvo
  pronajem
}

enum PropertyStatus {
  active
  inactive
  archived
}

model Unit {
  id         String   @id @default(uuid())
  propertyId String
  name       String
  floor      Int?
  area       Float?
  isOccupied Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property        Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  residents       Resident[]
  occupancies     Occupancy[]
  prescriptions   Prescription[]
  helpdeskTickets HelpdeskTicket[]
  leaseAgreements LeaseAgreement[]
  workOrders      WorkOrder[]
  meters          Meter[]
  assets          Asset[]

  @@index([propertyId])
  @@map("units")
}

// ─── RESIDENT ─────────────────────────────────────────────────────

model Resident {
  id         String       @id @default(uuid())
  tenantId   String
  propertyId String?
  unitId     String?
  firstName  String
  lastName   String
  email      String?
  phone      String?
  role       ResidentRole
  isActive   Boolean      @default(true)
  hasDebt    Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property         Property?         @relation(fields: [propertyId], references: [id])
  unit             Unit?             @relation(fields: [unitId], references: [id])
  occupancies      Occupancy[]
  prescriptions    Prescription[]
  bankTransactions BankTransaction[]
  reminders        Reminder[]
  helpdeskTickets  HelpdeskTicket[]
  leaseAgreements  LeaseAgreement[]

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([propertyId, isActive])
  @@index([tenantId, hasDebt])
  @@map("residents")
}

enum ResidentRole {
  owner
  tenant
  member
  contact
}

// ─── OCCUPANCY ────────────────────────────────────────────────────

model Occupancy {
  id         String        @id @default(uuid())
  tenantId   String
  unitId     String
  residentId String
  role       OccupancyRole
  startDate  DateTime
  endDate    DateTime?
  isActive   Boolean       @default(true)
  note       String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unit     Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  resident Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([unitId])
  @@index([residentId])
  @@map("occupancies")
}

enum OccupancyRole {
  owner
  tenant
  member
}

// ─── FINANCE ──────────────────────────────────────────────────────

model FinanceTransaction {
  id          String            @id @default(uuid())
  tenantId    String
  propertyId  String?
  type        TransactionType
  status      TransactionStatus @default(pending)
  amount      Decimal           @db.Decimal(12, 2)
  vatRate     Int               @default(0)
  vatAmount   Decimal           @db.Decimal(12, 2) @default(0)
  description String
  date        DateTime
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, date])
  @@map("finance_transactions")
}

enum TransactionType {
  income
  expense
  transfer
}

enum TransactionStatus {
  pending
  completed
  cancelled
}

// ─── FINANCE ROZŠÍŘENÍ ────────────────────────────────────────────

model BankAccount {
  id            String   @id @default(uuid())
  tenantId      String
  propertyId    String?
  name          String
  accountNumber String
  iban          String?
  bankCode      String?
  currency      String   @default("CZK")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property     Property?       @relation(fields: [propertyId], references: [id])
  transactions BankTransaction[]
  importLogs   ImportLog[]

  @@index([tenantId])
  @@map("bank_accounts")
}

model BankTransaction {
  id               String                @id @default(uuid())
  tenantId         String
  bankAccountId    String
  amount           Decimal               @db.Decimal(12, 2)
  type             BankTransactionType
  status           BankTransactionStatus @default(unmatched)
  date             DateTime
  counterparty     String?
  counterpartyIban String?
  variableSymbol   String?
  specificSymbol   String?
  constantSymbol   String?
  description      String?
  prescriptionId   String?
  residentId       String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bankAccount  BankAccount   @relation(fields: [bankAccountId], references: [id])
  prescription Prescription? @relation(fields: [prescriptionId], references: [id])
  resident     Resident?     @relation(fields: [residentId], references: [id])

  @@index([tenantId])
  @@index([tenantId, date])
  @@index([tenantId, status])
  @@index([bankAccountId, date])
  @@index([variableSymbol])
  @@map("bank_transactions")
}

enum BankTransactionType {
  credit
  debit
}

enum BankTransactionStatus {
  unmatched
  matched
  partially_matched
}

model BillingPeriod {
  id          String              @id @default(uuid())
  tenantId    String
  propertyId  String
  name        String
  dateFrom    DateTime
  dateTo      DateTime
  status      BillingPeriodStatus @default(open)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property      Property       @relation(fields: [propertyId], references: [id])
  prescriptions Prescription[]

  @@index([tenantId])
  @@index([propertyId])
  @@map("billing_periods")
}

enum BillingPeriodStatus {
  open
  closed
  settled
}

model Prescription {
  id              String             @id @default(uuid())
  tenantId        String
  propertyId      String
  unitId          String?
  residentId      String?
  billingPeriodId String?
  type            PrescriptionType
  status          PrescriptionStatus @default(active)
  amount          Decimal            @db.Decimal(12, 2)
  vatRate         Int                @default(0)
  vatAmount       Decimal            @db.Decimal(12, 2) @default(0)
  dueDay          Int                @default(15)
  variableSymbol  String?
  description     String
  validFrom       DateTime
  validTo         DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property      Property         @relation(fields: [propertyId], references: [id])
  unit          Unit?            @relation(fields: [unitId], references: [id])
  resident      Resident?        @relation(fields: [residentId], references: [id])
  billingPeriod BillingPeriod?   @relation(fields: [billingPeriodId], references: [id])
  items         PrescriptionItem[]
  transactions  BankTransaction[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([propertyId])
  @@index([residentId, status])
  @@index([variableSymbol])
  @@map("prescriptions")
}

enum PrescriptionType {
  advance
  service
  rent
  other
}

enum PrescriptionStatus {
  active
  inactive
  cancelled
}

model PrescriptionItem {
  id             String   @id @default(uuid())
  prescriptionId String
  name           String
  amount         Decimal  @db.Decimal(12, 2)
  vatRate        Int      @default(0)
  unit           String?
  quantity       Decimal  @db.Decimal(10, 3) @default(1)
  createdAt      DateTime @default(now())

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@index([prescriptionId])
  @@map("prescription_items")
}

// ─── REMINDERS ────────────────────────────────────────────────────

model ReminderTemplate {
  id         String           @id @default(uuid())
  tenantId   String
  name       String
  level      ReminderLevel
  subject    String
  body       String           @db.Text
  dueDays    Int              @default(14)
  isDefault  Boolean          @default(false)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reminders Reminder[]

  @@index([tenantId])
  @@map("reminder_templates")
}

enum ReminderLevel {
  first
  second
  third
}

model Reminder {
  id         String         @id @default(uuid())
  tenantId   String
  residentId String
  templateId String?
  level      ReminderLevel
  status     ReminderStatus @default(draft)
  amount     Decimal        @db.Decimal(12, 2)
  dueDate    DateTime
  sentAt     DateTime?
  note       String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  resident  Resident           @relation(fields: [residentId], references: [id])
  template  ReminderTemplate?  @relation(fields: [templateId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status, level])
  @@index([tenantId, dueDate])
  @@index([residentId])
  @@index([residentId, status])
  @@map("reminders")
}

enum ReminderStatus {
  draft
  sent
  paid
  escalated
}

// ─── HELPDESK ─────────────────────────────────────────────────────

model HelpdeskTicket {
  id          String         @id @default(uuid())
  tenantId    String
  propertyId  String?
  unitId      String?
  residentId  String?
  number      Int
  title       String
  description String?        @db.Text
  category    TicketCategory @default(general)
  priority    TicketPriority @default(medium)
  status      TicketStatus   @default(open)
  assigneeId  String?
  resolvedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property  Property?         @relation(fields: [propertyId], references: [id])
  unit      Unit?             @relation(fields: [unitId], references: [id])
  resident  Resident?         @relation(fields: [residentId], references: [id])
  assignee  User?             @relation(fields: [assigneeId], references: [id])
  items     HelpdeskItem[]
  protocol  HelpdeskProtocol?

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, status, createdAt])
  @@index([propertyId, status])
  @@map("helpdesk_tickets")
}

enum TicketCategory {
  general
  plumbing
  electrical
  hvac
  structural
  cleaning
  other
}

enum TicketPriority {
  low
  medium
  high
  urgent
}

enum TicketStatus {
  open
  in_progress
  resolved
  closed
}

model HelpdeskItem {
  id          String   @id @default(uuid())
  ticketId    String
  description String
  unit        String?
  quantity    Decimal  @db.Decimal(10, 3) @default(1)
  unitPrice   Decimal  @db.Decimal(12, 2) @default(0)
  totalPrice  Decimal  @db.Decimal(12, 2) @default(0)
  createdAt   DateTime @default(now())

  ticket HelpdeskTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("helpdesk_items")
}

model HelpdeskProtocol {
  id          String   @id @default(uuid())
  ticketId    String   @unique
  number      String
  workerName  String?
  workerDate  DateTime?
  clientName  String?
  clientSigned Boolean @default(false)
  note        String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ticket HelpdeskTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("helpdesk_protocols")
}

// ─── DOCUMENTS ────────────────────────────────────────────────────

model Document {
  id           String       @id @default(uuid())
  tenantId     String
  name         String
  originalName String
  mimeType     String
  size         Int
  storageKey   String       @unique
  storageType  StorageType  @default(local)
  category     DocCategory  @default(other)
  description  String?
  isPublic     Boolean      @default(false)
  createdById  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?           @relation(fields: [createdById], references: [id])
  tags      DocumentTag[]
  links     DocumentLink[]

  @@index([tenantId])
  @@index([tenantId, category])
  @@index([tenantId, createdAt])
  @@map("documents")
}

enum StorageType {
  local
  s3
}

enum DocCategory {
  contract
  invoice
  protocol
  photo
  plan
  regulation
  other
}

model DocumentTag {
  id         String   @id @default(uuid())
  documentId String
  tag        String
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, tag])
  @@index([tag])
  @@map("document_tags")
}

model DocumentLink {
  id         String     @id @default(uuid())
  documentId String
  entityType EntityType
  entityId   String
  createdAt  DateTime   @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@map("document_links")
}

enum EntityType {
  property
  unit
  resident
  ticket
  prescription
  reminder
}

// ─── SETTINGS ─────────────────────────────────────────────────────

model TenantSettings {
  id               String   @id @default(uuid())
  tenantId         String   @unique

  // Firma
  orgName          String?
  orgStreet        String?
  orgCity          String?
  orgZip           String?
  orgCountry       String?  @default("CZ")
  orgPhone         String?
  orgEmail         String?
  orgWeb           String?
  companyNumber    String?
  vatNumber        String?

  // Branding
  logoBase64       String?  @db.Text
  logoUrl          String?
  primaryColor     String?  @default("#6366f1")
  themeMode        String?  @default("light")

  // Regional
  timezone         String   @default("Europe/Prague")
  currency         String   @default("CZK")
  language         String   @default("cs")
  dateFormat       String?  @default("DD.MM.YYYY")

  // Email
  emailFrom        String?
  emailReplyTo     String?
  emailSignature   String?  @db.Text
  notifNewTicket   Boolean  @default(true)
  notifWoAssigned  Boolean  @default(true)
  notifContractExp Boolean  @default(true)
  notifMeterDue    Boolean  @default(true)
  notifPaymentDue  Boolean  @default(true)

  // Invoicing
  invoicePrefix    String?  @default("FV")
  contractPrefix   String?  @default("SM")
  invoiceDueDays   Int      @default(14)
  defaultVat       Int      @default(21)
  invoiceFooter    String?  @db.Text
  bankAccount      String?

  // Reminders
  reminderDaysBefore Int    @default(7)
  reminderText1    String?  @db.Text
  reminderText2    String?  @db.Text

  address          String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

// ─── IMPORT LOG ───────────────────────────────────────────────────

model ImportLog {
  id            String       @id @default(uuid())
  tenantId      String
  bankAccountId String?
  format        ImportFormat
  fileName      String?
  totalRows     Int          @default(0)
  importedRows  Int          @default(0)
  skippedRows   Int          @default(0)
  errorRows     Int          @default(0)
  status        ImportStatus @default(pending)
  errors        Json?
  createdById   String?
  createdAt     DateTime     @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bankAccount BankAccount? @relation(fields: [bankAccountId], references: [id])

  @@index([tenantId])
  @@map("import_logs")
}

enum ImportFormat {
  csv
  abo
  mt940
  residents
}

enum ImportStatus {
  pending
  processing
  done
  failed
}

// ─── NOTIFICATIONS ───────────────────────────────────────────────

model Notification {
  id         String    @id @default(cuid())
  tenantId   String
  userId     String?
  type       String
  title      String
  body       String
  entityId   String?
  entityType String?
  url        String?
  isRead     Boolean   @default(false)
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, isRead, createdAt])
  @@index([userId, isRead])
  @@map("notifications")
}

// ─── LEASE AGREEMENTS ────────────────────────────────────────────

model LeaseAgreement {
  id              String          @id @default(uuid())
  tenantId        String
  propertyId      String
  unitId          String?
  residentId      String?
  contractNumber  String?
  contractType    ContractType    @default(najem)
  status          ContractStatus  @default(aktivni)
  monthlyRent     Decimal         @db.Decimal(12, 2)
  deposit         Decimal?        @db.Decimal(12, 2)
  depositPaid     Decimal?        @db.Decimal(12, 2)
  startDate       DateTime
  endDate         DateTime?
  indefinite      Boolean         @default(false)
  noticePeriod    Int             @default(3)
  renewalType     RenewalType     @default(pisemna)
  terminatedAt    DateTime?
  terminationNote String?
  note            String?         @db.Text
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property Property  @relation(fields: [propertyId], references: [id])
  unit     Unit?     @relation(fields: [unitId], references: [id])
  resident Resident? @relation(fields: [residentId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, endDate])
  @@index([propertyId])
  @@index([residentId])
  @@map("lease_agreements")
}

enum ContractType {
  najem
  podnajem
  sluzebni
  jiny
}

enum ContractStatus {
  aktivni
  ukoncena
  pozastavena
  pripravovana
}

enum RenewalType {
  pisemna
  automaticka
  nevztahuje
}

// ─── WORK ORDERS ─────────────────────────────────────────────────

model WorkOrder {
  id              String          @id @default(uuid())
  tenantId        String
  propertyId      String?
  unitId          String?
  title           String
  description     String?         @db.Text
  workType        WorkType        @default(corrective)
  priority        WOPriority      @default(normalni)
  status          WOStatus        @default(nova)
  assignee        String?
  requester       String?
  deadline        DateTime?
  completedAt     DateTime?
  estimatedHours  Float?
  actualHours     Float?
  laborCost       Decimal?        @db.Decimal(12, 2)
  materialCost    Decimal?        @db.Decimal(12, 2)
  totalCost       Decimal?        @db.Decimal(12, 2)
  note            String?         @db.Text
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id])
  unit     Unit?     @relation(fields: [unitId], references: [id])
  comments WorkOrderComment[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, priority])
  @@index([tenantId, deadline])
  @@index([propertyId])
  @@map("work_orders")
}

model WorkOrderComment {
  id          String   @id @default(uuid())
  workOrderId String
  author      String
  text        String   @db.Text
  createdAt   DateTime @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
  @@map("work_order_comments")
}

enum WorkType {
  corrective
  preventive
  inspection
  emergency
}

enum WOPriority {
  nizka
  normalni
  vysoka
  kriticka
}

enum WOStatus {
  nova
  v_reseni
  vyresena
  uzavrena
  zrusena
}

// ─── METERS ──────────────────────────────────────────────────────

model Meter {
  id              String      @id @default(uuid())
  tenantId        String
  propertyId      String?
  unitId          String?
  name            String
  serialNumber    String
  meterType       MeterType
  unit            String      @default("kWh")
  installDate     DateTime?
  calibrationDate DateTime?
  calibrationDue  DateTime?
  manufacturer    String?
  location        String?
  isActive        Boolean     @default(true)
  lastReading     Float?
  lastReadingDate DateTime?
  note            String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property  Property?      @relation(fields: [propertyId], references: [id])
  unitRel   Unit?          @relation(fields: [unitId], references: [id])
  readings  MeterReading[]

  @@index([tenantId])
  @@map("meters")
}

model MeterReading {
  id          String   @id @default(uuid())
  meterId     String
  readingDate DateTime
  value       Float
  consumption Float?
  source      String   @default("manual")
  readBy      String?
  note        String?
  createdAt   DateTime @default(now())

  meter Meter @relation(fields: [meterId], references: [id], onDelete: Cascade)

  @@index([meterId])
  @@map("meter_readings")
}

enum MeterType {
  elektrina
  voda_studena
  voda_tepla
  plyn
  teplo
}

// ─── CALENDAR EVENTS ────────────────────────────────────────────

model CalendarEvent {
  id          String        @id @default(uuid())
  tenantId    String
  propertyId  String?
  title       String
  eventType   CalEventType  @default(ostatni)
  date        DateTime
  dateTo      DateTime?
  timeFrom    String?
  timeTo      String?
  location    String?
  description String?       @db.Text
  attendees   String[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, date])
  @@map("calendar_events")
}

enum CalEventType {
  schuze
  revize
  udrzba
  predani
  prohlidka
  ostatni
}

// ─── ASSET MANAGEMENT ────────────────────────────────────────────

model Asset {
  id              String         @id @default(uuid())
  tenantId        String
  propertyId      String?
  unitId          String?
  name            String
  category        AssetCategory  @default(ostatni)
  manufacturer    String?
  model           String?
  serialNumber    String?
  location        String?
  status          AssetStatus    @default(aktivni)
  purchaseDate    DateTime?
  purchaseValue   Decimal?       @db.Decimal(12, 2)
  warrantyUntil   DateTime?
  serviceInterval Int?           // months
  lastServiceDate DateTime?
  nextServiceDate DateTime?
  notes           String?        @db.Text
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property        Property?      @relation(fields: [propertyId], references: [id])
  unit            Unit?          @relation(fields: [unitId], references: [id])
  serviceRecords  AssetServiceRecord[]

  @@index([tenantId])
  @@index([propertyId])
  @@map("assets")
}

enum AssetCategory {
  tzb
  stroje
  vybaveni
  vozidla
  it
  ostatni
}

enum AssetStatus {
  aktivni
  servis
  vyrazeno
  neaktivni
}

model AssetServiceRecord {
  id          String   @id @default(uuid())
  assetId     String
  tenantId    String
  date        DateTime
  type        String   // preventivni, oprava, revize, kalibrace
  description String?  @db.Text
  cost        Decimal? @db.Decimal(12, 2)
  supplier    String?
  createdAt   DateTime @default(now())

  asset  Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([tenantId])
  @@map("asset_service_records")
}
