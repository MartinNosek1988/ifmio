  requesterUser   User?              @relation("WORequester", fields: [requesterUserId], references: [id], onDelete: SetNull)
  dispatcherUser  User?              @relation("WODispatcher", fields: [dispatcherUserId], references: [id], onDelete: SetNull)
  comments        WorkOrderComment[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, priority])
  @@index([tenantId, deadline])
  @@index([propertyId])
  @@index([assetId])
  @@index([helpdeskTicketId])
