generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── TENANT ──────────────────────────────────────────────────────

model Tenant {
  id            String     @id @default(uuid())
  name          String
  slug          String     @unique
  plan          TenantPlan @default(free)
  isActive      Boolean    @default(true)
  ico           String?    // IČO správcovské firmy
  dic           String?    // DIČ správcovské firmy
  maxUsers      Int        @default(5)
  maxProperties Int        @default(3)
  trialEndsAt   DateTime?
  notes         String?
  // Data retention policies (ZT-W5-02)
  retentionAuditLogDays  Int  @default(365)
  retentionBackupDays    Int  @default(90)
  retentionSessionDays   Int  @default(30)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  users               User[]
  properties          Property[]
  residents           Resident[]
  transactions        FinanceTransaction[]
  auditLogs           AuditLog[]
  occupancies         Occupancy[]
  bankAccounts        BankAccount[]
  bankTransactions    BankTransaction[]
  billingPeriods      BillingPeriod[]
  prescriptions       Prescription[]
  reminderTemplates   ReminderTemplate[]
  reminders           Reminder[]
  helpdeskTickets     HelpdeskTicket[]
  documents           Document[]
  settings            TenantSettings?
  importLogs          ImportLog[]
  notifications       Notification[]
  leaseAgreements     LeaseAgreement[]
  workOrders          WorkOrder[]
  meters              Meter[]
  calendarEvents      CalendarEvent[]
  assets              Asset[]
  assetServiceRecords AssetServiceRecord[]
  invoices            Invoice[]
  slaPolicies         SlaPolicy[]
  revisionSubjects    RevisionSubject[]
  revisionTypes       RevisionType[]
  revisionPlans       RevisionPlan[]
  revisionEvents      RevisionEvent[]
  protocols           Protocol[]
  assetTypes          AssetType[]
  assetTypeRevisionTypes AssetTypeRevisionType[]
  assetQrCodes        AssetQrCode[]
  assetQrScanEvents   AssetQrScanEvent[]
  fieldCheckExecutions AssetFieldCheckExecution[]
  reportSubscriptions  ScheduledReportSubscription[]
  recurringPlans       RecurringActivityPlan[]
  mioFindings          MioFinding[]
  mioDigestLogs        MioDigestLog[]
  mioWebhookSubscriptions MioWebhookSubscription[]

  // Principal & Financial Context Layer
  parties                     Party[]
  principals                  Principal[]
  principalOwners             PrincipalOwner[]
  managementContracts         ManagementContract[]
  managementContractUnits     ManagementContractUnit[]
  propertyOwnerships          PropertyOwnership[]
  unitOwnerships              UnitOwnership[]
  tenancies                   Tenancy[]
  financialContexts           FinancialContext[]
  settlements                 Settlement[]
  outboxLogs                  OutboxLog[]
  invitations                 TenantInvitation[]
  kanbanTasks                 KanbanTask[]
  apiKeys                     ApiKey[]
  unitGroups                  UnitGroup[]
  accountingPresets           AccountingPreset[]
  portalAccess               PortalAccess[]
  portalMessages             PortalMessage[]
  unitRooms                  UnitRoom[]
  unitQuantities             UnitQuantity[]
  unitEquipment              UnitEquipment[]
  unitManagementFees         UnitManagementFee[]
  evidenceFolders            EvidenceFolder[]
  paymentOrders              PaymentOrder[]
  aiExtractionLogs           AiExtractionLog[]
  supplierExtractionPatterns SupplierExtractionPattern[]
  aiExtractionBatches        AiExtractionBatch[]
  invoiceTrainingSamples     InvoiceTrainingSample[]
  invoiceComments            InvoiceComment[]

  @@map("tenants")
}

enum TenantPlan {
  free
  starter
  pro
  enterprise
}

// ─── USER ─────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  tenantId     String
  email        String
  passwordHash String?
  name         String
  role         UserRole  @default(viewer)
  isActive     Boolean   @default(true)
  partyId      String?
  phone        String?
  position     String?
  avatarBase64 String?
  language     String    @default("cs")
  timezone     String    @default("Europe/Prague")
  dateFormat   String    @default("DD.MM.YYYY")
  notifEmail   Boolean   @default(true)
  passwordResetToken   String?   @unique
  passwordResetExpiry  DateTime?
  passwordHistory      Json?              // array of last 5 bcrypt hashes
  passwordChangedAt    DateTime?          // when password was last changed
  passwordExpiresAt    DateTime?          // null = never expires
  forcePasswordChange  Boolean   @default(false)
  totpSecret           String?              // AES-encrypted TOTP secret
  totpEnabled          Boolean   @default(false)
  totpBackupCodes      Json?               // array of hashed backup codes
  oauthProvider        String?              // 'google' | 'facebook' | 'microsoft'
  oauthId              String?              // provider's unique user ID
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant                  Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  party                   Party?                   @relation("UserParty", fields: [partyId], references: [id], onDelete: SetNull)
  refreshTokens           RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]
  sentInvitations         TenantInvitation[]       @relation("InvitedBy")
  auditLogs               AuditLog[]
  assignedTickets         HelpdeskTicket[]  @relation("TicketAssignee")
  requestedTickets        HelpdeskTicket[]  @relation("TicketRequester")
  dispatchedTickets       HelpdeskTicket[]  @relation("TicketDispatcher")
  createdDocuments        Document[]
  notifications           Notification[]
  propertyAssignments     UserPropertyAssignment[]
  submittedInvoices       Invoice[]                @relation("InvoiceSubmitter")
  approvedInvoices        Invoice[]                @relation("InvoiceApprover")
  rejectedInvoices        Invoice[]                @relation("InvoiceRejecter")
  responsiblePlans        RevisionPlan[]
  qrScanEvents            AssetQrScanEvent[]
  fieldCheckExecutions    AssetFieldCheckExecution[]
  assignedWorkOrders      WorkOrder[]               @relation("WOAssignee")
  requestedWorkOrders     WorkOrder[]               @relation("WORequester")
  dispatchedWorkOrders    WorkOrder[]               @relation("WODispatcher")
  woDispatchedBy          WorkOrder[]               @relation("WODispatchedBy")
  reportSubscriptions     ScheduledReportSubscription[]
  assignedRecurringPlans  RecurringActivityPlan[]       @relation("RecurringPlanAssignee")
  mioDigestLogs           MioDigestLog[]
  kanbanTasksAssigned     KanbanTask[]             @relation("KanbanTaskAssignee")
  kanbanTasksCreated      KanbanTask[]             @relation("KanbanTaskCreator")
  features                UserFeature[]
  apiKeys                 ApiKey[]
  paymentOrders           PaymentOrder[]
  invoiceComments         InvoiceComment[]
  chatMessages            ChatMessage[]    @relation("ChatAuthor")
  chatMentions            ChatMention[]    @relation("ChatMentioned")
  assignedActivities      Activity[]       @relation("ActivityAssigned")
  doneActivities          Activity[]       @relation("ActivityDone")

  @@unique([tenantId, email])
  @@unique([oauthProvider, oauthId])
  @@index([tenantId])
  @@map("users")
}

enum UserRole {
  tenant_owner
  tenant_admin
  property_manager
  finance_manager
  operations
  viewer
  unit_owner
  unit_tenant
}

model TenantInvitation {
  id          String    @id @default(uuid())
  tenantId    String
  email       String
  name        String
  role        UserRole
  token       String    @unique
  propertyId  String?
  unitId      String?
  expiresAt   DateTime
  acceptedAt  DateTime?
  invitedById String
  createdAt   DateTime  @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy User      @relation("InvitedBy", fields: [invitedById], references: [id])
  property  Property? @relation(fields: [propertyId], references: [id])
  unit      Unit?     @relation(fields: [unitId], references: [id])

  @@index([tenantId])
  @@index([token])
  @@map("tenant_invitations")
}

// ─── OWNER PORTAL (public token-based access) ─────────────────

model PortalAccess {
  id              String    @id @default(cuid())
  tenantId        String
  residentId      String    // link to Resident (owner/tenant)
  email           String
  accessToken     String    @unique @default(cuid())
  pin             String?   // optional PIN for extra security
  isActive        Boolean   @default(true)
  lastAccessAt    DateTime?
  expiresAt       DateTime? // null = never expires
  createdAt       DateTime  @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  resident  Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([accessToken])
  @@index([tenantId, residentId])
  @@map("portal_access")
}

model PortalMessage {
  id              String    @id @default(cuid())
  tenantId        String
  residentId      String
  propertyId      String?
  subject         String
  body            String    @db.Text
  direction       String    // 'inbound' (owner→admin) | 'outbound' (admin→owner)
  isRead          Boolean   @default(false)
  createdAt       DateTime  @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  resident  Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)

  @@index([tenantId, residentId])
  @@index([tenantId, direction, isRead])
  @@map("portal_messages")
}

// ─── SIPO (Soustředěné inkaso plateb obyvatelstva) ──────────────

model SipoConfig {
  id              String           @id @default(cuid())
  tenantId        String
  propertyId      String           @unique
  recipientNumber String           @db.VarChar(6)   // Číslo Příjemce (6-místné)
  feeCode         String           @db.VarChar(3)   // Kód poplatku (3-místné)
  deliveryMode    SipoDeliveryMode @default(FULL_REGISTER)
  encoding        SipoEncoding     @default(WIN1250)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  property        Property         @relation(fields: [propertyId], references: [id])

  @@index([tenantId])
  @@map("sipo_configs")
}

enum SipoDeliveryMode {
  FULL_REGISTER    // celý kmen plátců
  CHANGES_ONLY     // jen změny
}

enum SipoEncoding {
  CP852
  WIN1250
}

model SipoExport {
  id              String           @id @default(cuid())
  tenantId        String
  propertyId      String
  period          String           @db.VarChar(6)   // MMRRRR
  recordCount     Int
  totalAmount     Decimal          @db.Decimal(12, 2)
  fileName        String
  status          SipoExportStatus @default(GENERATED)
  errorFile       String?          @db.Text
  createdAt       DateTime         @default(now())

  property        Property         @relation(fields: [propertyId], references: [id])

  @@index([tenantId])
  @@index([propertyId, period])
  @@map("sipo_exports")
}

enum SipoExportStatus {
  GENERATED
  SENT
  ACCEPTED
  REJECTED
  PARTIALLY_OK
}

model SipoPayment {
  id              String   @id @default(cuid())
  tenantId        String
  propertyId      String
  period          String   @db.VarChar(6)
  sipoNumber      String   @db.VarChar(10)
  recipientNumber String   @db.VarChar(6)
  feeCode         String   @db.VarChar(3)
  amount          Decimal  @db.Decimal(12, 2)
  paymentDate     DateTime
  matchedToKonto  Boolean  @default(false)
  importedAt      DateTime @default(now())

  property        Property @relation(fields: [propertyId], references: [id])

  @@index([tenantId])
  @@index([sipoNumber, period])
  @@map("sipo_payments")
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String
  token      String    @unique
  expiresAt  DateTime
  ipAddress  String?
  userAgent  String?
  deviceName String?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

// ─── AUDIT LOG ────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String?
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldData   Json?
  newData   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, entity])
  @@index([tenantId, createdAt])
  @@index([tenantId, entity, action])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

// ─── PROPERTY ─────────────────────────────────────────────────────

model Property {
  id               String             @id @default(uuid())
  tenantId         String
  name             String
  address          String
  city             String
  postalCode       String
  type             PropertyType
  ownership        OwnershipType
  status           PropertyStatus     @default(active)
  ico              String?            // IČ subjektu (SVJ/BD)
  dic              String?            // DIČ
  isVatPayer       Boolean            @default(false)
  dataBoxId        String?            // ID datové schránky SVJ/BD z ARES
  legalMode        PropertyLegalMode  @default(OWNERSHIP)
  managedFrom      DateTime?          // ve správě od
  managedTo        DateTime?          // ve správě do
  accountingSystem AccountingSystem?
  cutoverDate      DateTime?          // datum přechodu na ifmio
  importSource     String?            // "cuzk_domsys" etc.
  importedAt       DateTime?
  cadastralData    Json?              // raw ČÚZK metadata (building, parcel, k.ú.)
  cadastralArea    String?            // katastrální území (text)
  landRegistrySheet String?           // list vlastnictví (LV)
  country          String             @default("CZ")
  matchStrategy    MatchStrategy      @default(OLDEST_FIRST)  // Strategie párování plateb
  // Contact & web
  contactName      String?
  contactEmail     String?
  contactPhone     String?
  website          String?
  websiteNote      String?
  // Geocoding
  latitude         Float?
  longitude        Float?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  units           Unit[]
  residents       Resident[]
  bankAccounts    BankAccount[]
  billingPeriods  BillingPeriod[]
  prescriptions   Prescription[]
  helpdeskTickets HelpdeskTicket[]
  leaseAgreements LeaseAgreement[]
  workOrders      WorkOrder[]
  meters          Meter[]
  assets          Asset[]
  invoices        Invoice[]
  protocols       Protocol[]

  userAssignments  UserPropertyAssignment[]
  slaPolicies      SlaPolicy[]
  revisionSubjects RevisionSubject[]
  revisionPlans    RevisionPlan[]
  revisionEvents        RevisionEvent[]
  reportSubscriptions   ScheduledReportSubscription[]
  recurringPlans        RecurringActivityPlan[]
  ownerAccounts              OwnerAccount[]
  kontoReminders             KontoReminder[]
  prescriptionComponents     PrescriptionComponent[]

  // Principal & Financial Context Layer
  managementContracts        ManagementContract[]
  propertyOwnerships         PropertyOwnership[]
  financialContexts          FinancialContext[]
  settlements                Settlement[]
  invitations                TenantInvitation[]
  kanbanTasks                KanbanTask[]
  unitGroups                 UnitGroup[]
  assemblies                 Assembly[]
  perRollamVotings           PerRollamVoting[]
  initialBalances            InitialBalance[]
  sipoConfig                 SipoConfig?
  sipoExports                SipoExport[]
  sipoPayments               SipoPayment[]
  floorPlans                 FloorPlan[]
  evidenceFolders            EvidenceFolder[]

  @@index([tenantId])
  @@map("properties")
}

// ─── USER ↔ PROPERTY ASSIGNMENT ─────────────────────────────────

model UserPropertyAssignment {
  id         String   @id @default(uuid())
  userId     String
  propertyId String
  assignedBy String?
  assignedAt DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
  @@map("user_property_assignments")
}

enum PropertyType {
  bytdum
  roddum
  komer
  prumysl
  pozemek
  garaz
}

enum OwnershipType {
  vlastnictvi
  druzstvo
  pronajem
}

enum PropertyStatus {
  active
  inactive
  archived
}

enum PropertyLegalMode {
  SVJ
  BD
  RENTAL
  OWNERSHIP
  OTHER
}

enum AccountingSystem {
  POHODA
  MONEY_S3
  PREMIER
  VARIO
  NONE
}

enum MatchStrategy {
  OLDEST_FIRST   // Nejstarší neuhrazený předpis první
  SAME_MONTH     // Předpis za stejný měsíc jako datum platby
  EXACT_AMOUNT   // Jen pokud částka přesně odpovídá
}

model Unit {
  id                 String    @id @default(uuid())
  propertyId         String
  name               String
  floor              Int?
  area               Float?                          // podlahová plocha m²
  isOccupied         Boolean   @default(false)
  knDesignation      String?                         // KN označení "123/45"
  ownDesignation     String?                         // vlastní označení (č. dveří)
  spaceType          SpaceType @default(RESIDENTIAL)
  commonAreaShare    Decimal?  @db.Decimal(10, 6)    // podíl na společných částech (0.034567)
  heatingArea        Float?                          // vytápěná plocha m²
  tuvArea            Float?                          // plocha pro TUV m²
  heatingCoefficient Float?                          // koeficient vytápění
  hotWaterCoefficient Float?                         // koeficient TUV
  personCount        Int?                            // výchozí počet osob
  disposition        String?                         // 1+1, 2+kk
  hasElevator        Boolean?
  heatingMethod      String?                         // způsob vytápění
  validFrom          DateTime?
  validTo            DateTime?
  extAllocatorRef    String?                         // pár. symbol pro ext. rozúčtovatele
  cadastralData      Json?                           // ČÚZK metadata (LV, omezení, ochrana, řízení)
  isGarageUnit       Boolean   @default(false)       // garážová jednotka — vyžaduje vnitřní hlasování
  garageVotingRule   GarageVotingRule @default(PRESENT_MAJORITY)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  property        Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  residents       Resident[]
  occupancies     Occupancy[]
  prescriptions   Prescription[]
  helpdeskTickets HelpdeskTicket[]
  leaseAgreements LeaseAgreement[]
  workOrders      WorkOrder[]
  meters          Meter[]
  assets          Asset[]
  ownerAccounts        OwnerAccount[]
  kontoReminders       KontoReminder[]
  componentAssignments     ComponentAssignment[]

  // Principal & Financial Context Layer
  managementContractUnits  ManagementContractUnit[]
  unitOwnerships           UnitOwnership[]
  tenancies                Tenancy[]
  settlementItems          SettlementItem[]
  invitations              TenantInvitation[]
  groupMemberships         UnitGroupMembership[]

  // Unit detail tabs (Domsys parity)
  rooms          UnitRoom[]
  quantities     UnitQuantity[]
  equipment      UnitEquipment[]
  managementFees UnitManagementFee[]
  floorPlanZones FloorPlanZone[]

  @@index([propertyId])
  @@map("units")
}

model UnitRoom {
  id             String   @id @default(uuid())
  unitId         String
  unit           Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  name           String
  area           Float
  coefficient    Float    @default(1.0)
  calculatedArea Float?
  roomType       String   @default("standard") // "standard" | "accessory"
  includeTuv     Boolean  @default(true)
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId, unitId])
  @@map("unit_rooms")
}

model UnitQuantity {
  id        String @id @default(uuid())
  unitId    String
  unit      Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  name      String
  value     Float
  unitLabel String @default("")
  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, unitId, name])
  @@index([tenantId, unitId])
  @@map("unit_quantities")
}

model UnitEquipment {
  id                String    @id @default(uuid())
  unitId            String
  unit              Unit      @relation(fields: [unitId], references: [id], onDelete: Cascade)
  name              String
  status            String    @default("functional")
  note              String?
  quantity          Float     @default(1)
  serialNumber      String?
  purchaseDate      DateTime?
  purchasePrice     Float?
  installPrice      Float?
  warranty          Int?       // months
  lifetime          Int?       // months
  rentDuring        Float?
  rentAfter         String?
  useInPrescription Boolean   @default(true)
  validFrom         DateTime?
  validTo           DateTime?
  description       String?
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([tenantId, unitId])
  @@map("unit_equipment")
}

model UnitManagementFee {
  id              String    @id @default(uuid())
  unitId          String
  unit            Unit      @relation(fields: [unitId], references: [id], onDelete: Cascade)
  amount          Float
  calculationType String    @default("flat")
  validFrom       DateTime
  validTo         DateTime?
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tenantId, unitId])
  @@map("unit_management_fees")
}

enum SpaceType {
  RESIDENTIAL
  NON_RESIDENTIAL
  GARAGE
  PARKING
  CELLAR
  LAND
}

// ─── RESIDENT ─────────────────────────────────────────────────────

model Resident {
  id                       String       @id @default(uuid())
  tenantId                 String
  propertyId               String?
  unitId                   String?
  firstName                String
  lastName                 String
  email                    String?
  phone                    String?
  role                     ResidentRole
  isActive                 Boolean      @default(true)
  hasDebt                  Boolean      @default(false)
  isLegalEntity            Boolean      @default(false)
  ico                      String?      // IČ právnické osoby
  dic                      String?      // DIČ
  companyName              String?      // název firmy
  correspondenceAddress    String?
  correspondenceCity       String?
  correspondencePostalCode String?
  dataBoxId                String?      // ID datové schránky
  birthDate                DateTime?
  note                     String?      @db.Text
  // GDPR (ZT-W5-01)
  gdprErased               Boolean      @default(false)
  gdprErasedAt             DateTime?

  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  partyId          String?

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property         Property?         @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  unit             Unit?             @relation(fields: [unitId], references: [id], onDelete: SetNull)
  party            Party?            @relation(fields: [partyId], references: [id], onDelete: SetNull)
  occupancies      Occupancy[]
  prescriptions    Prescription[]
  bankTransactions BankTransaction[]
  reminders        Reminder[]
  helpdeskTickets  HelpdeskTicket[]
  leaseAgreements  LeaseAgreement[]
  supplierInvoices Invoice[]         @relation("InvoiceSupplier")
  buyerInvoices    Invoice[]         @relation("InvoiceBuyer")
  ownerAccounts    OwnerAccount[]
  kontoReminders   KontoReminder[]
  portalAccess     PortalAccess[]
  portalMessages   PortalMessage[]

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([propertyId, isActive])
  @@index([tenantId, hasDebt])
  @@index([partyId])
  @@map("residents")
}

enum ResidentRole {
  owner
  tenant
  member
  contact
}

// ─── OCCUPANCY ────────────────────────────────────────────────────

model Occupancy {
  id              String        @id @default(uuid())
  tenantId        String
  unitId          String
  residentId      String
  role            OccupancyRole
  startDate       DateTime
  endDate         DateTime?
  isActive        Boolean       @default(true)
  ownershipShare  Decimal?      @db.Decimal(10, 6) // podíl spoluvlastníka (0.5 = 50%)
  personCount     Int?          // počet osob v domácnosti (přepíše unit.personCount)
  isPrimaryPayer  Boolean       @default(true) // kdo dostane předpis
  variableSymbol  String?       // VS přiřazený tomuto vztahu
  sipoNumber      String?       @db.VarChar(10) // SIPO spojovací číslo plátce
  note            String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unit     Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  resident Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([unitId])
  @@index([residentId])
  @@index([variableSymbol])
  @@map("occupancies")
}

enum OccupancyRole {
  owner
  tenant
  member
}

// ─── FINANCE ──────────────────────────────────────────────────────

model FinanceTransaction {
