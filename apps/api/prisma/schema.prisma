  @@index([tenantId])
  @@index([tenantId, status, level])
  @@index([tenantId, dueDate])
  @@index([residentId])
  @@index([residentId, status])
  @@map("reminders")
}

enum ReminderStatus {
  draft
  sent
  paid
  escalated
}

// ─── RECURRING ACTIVITY PLANS ─────────────────────────────────────

model RecurringActivityPlan {
  id               String   @id @default(uuid())
  tenantId         String
  propertyId       String?
  assetId          String?
  title            String
  description      String?  @db.Text
  category         String   @default("maintenance") // maintenance, inspection, reading, revision
  scheduleMode     String   @default("calendar")    // calendar | from_completion
  frequencyUnit    String   @default("day")          // day | week | month | year
  frequencyInterval Int     @default(1)
  dayOfWeek        Int?     // 0=Sun..6=Sat for weekly
  dayOfMonth       Int?     // 1-31 for monthly
  monthOfYear      Int?     // 1-12 for yearly
  leadDays         Int      @default(0)
  priority         String   @default("medium")       // low | medium | high | urgent
  assigneeUserId   String?
  isActive         Boolean  @default(true)
  lastCompletedAt  DateTime?
  nextPlannedAt    DateTime?
  lastGeneratedAt  DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  asset    Asset?    @relation(fields: [assetId], references: [id], onDelete: SetNull)
  assignee User?     @relation("RecurringPlanAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  generatedTickets HelpdeskTicket[]

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([assetId])
  @@index([tenantId, isActive, nextPlannedAt])
  @@map("recurring_activity_plans")
}

// ─── HELPDESK ─────────────────────────────────────────────────────

model HelpdeskTicket {
  id          String         @id @default(uuid())
  tenantId    String
  propertyId  String?
  unitId      String?
  residentId  String?
  assetId     String?
  number      Int
  title       String
  description String?        @db.Text
  category    TicketCategory @default(general)
  priority    TicketPriority @default(medium)
  status      TicketStatus   @default(open)
  assigneeId  String?
  requesterUserId  String?
  dispatcherUserId String?
  resolvedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // SLA fields
  responseDueAt      DateTime?
  resolutionDueAt    DateTime?
  deadlineManuallySet Boolean  @default(false)
  firstResponseAt    DateTime?
  escalationLevel    Int       @default(0)
  escalatedAt        DateTime?

  // Recurring generation tracking
  recurringPlanId    String?
  generationKey      String?   @unique
  plannedForDate     DateTime?
  requestOrigin      String?   // 'manual' | 'recurring_plan' | 'revision'
  recurringCompletionAppliedAt DateTime?  // idempotence: set once when plan is advanced
  deletedAt   DateTime?

  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property  Property?         @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  unit      Unit?             @relation(fields: [unitId], references: [id], onDelete: SetNull)
  resident  Resident?         @relation(fields: [residentId], references: [id], onDelete: SetNull)
  asset     Asset?            @relation(fields: [assetId], references: [id], onDelete: SetNull)
  assignee  User?             @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  requester User?             @relation("TicketRequester", fields: [requesterUserId], references: [id], onDelete: SetNull)
  dispatcher User?            @relation("TicketDispatcher", fields: [dispatcherUserId], references: [id], onDelete: SetNull)
  recurringPlan RecurringActivityPlan? @relation(fields: [recurringPlanId], references: [id], onDelete: SetNull)
  items      HelpdeskItem[]
  protocol   HelpdeskProtocol?
  workOrders WorkOrder[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, status, createdAt])
  @@index([propertyId, status])
  @@index([tenantId, resolutionDueAt])
  @@index([assetId])
  @@index([recurringPlanId])
  @@unique([tenantId, number])
  @@map("helpdesk_tickets")
}

enum TicketCategory {
  general
  plumbing
  electrical
  hvac
  structural
  cleaning
  other
}

enum TicketPriority {
  low
  medium
  high
  urgent
}

enum TicketStatus {
  open
  in_progress
  resolved
  closed
}

model HelpdeskItem {
  id          String   @id @default(uuid())
  ticketId    String
  description String
  unit        String?
  quantity    Decimal  @default(1) @db.Decimal(10, 3)
  unitPrice   Decimal  @default(0) @db.Decimal(12, 2)
  totalPrice  Decimal  @default(0) @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  ticket HelpdeskTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("helpdesk_items")
}

model HelpdeskProtocol {
  id           String    @id @default(uuid())
  ticketId     String    @unique
  number       String
  workerName   String?
  workerDate   DateTime?
  clientName   String?
  clientSigned Boolean   @default(false)
  note         String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  ticket HelpdeskTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("helpdesk_protocols")
}

model SlaPolicy {
  id         String  @id @default(uuid())
  tenantId   String
  propertyId String?

  // Hours per priority
  lowResponseH      Int @default(72)
  lowResolutionH    Int @default(336)
  mediumResponseH   Int @default(24)
  mediumResolutionH Int @default(120)
  highResponseH     Int @default(8)
  highResolutionH   Int @default(48)
  urgentResponseH   Int @default(1)
  urgentResolutionH Int @default(8)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([tenantId, propertyId])
  @@index([tenantId])
  @@map("sla_policies")
}

// ─── PROTOCOLS & HANDOVER ─────────────────────────────────────────

enum ProtocolSourceType {
  helpdesk
  revision
  work_order
}

enum ProtocolType {
  work_report
  handover
  revision_report
  service_protocol
}

enum ProtocolStatus {
  draft
  completed
  confirmed
}

enum Satisfaction {
  satisfied
  partially_satisfied
  dissatisfied
  neutral
}

model Protocol {
  id           String             @id @default(uuid())
  tenantId     String
  propertyId   String?
  sourceType   ProtocolSourceType
  sourceId     String
  protocolType ProtocolType       @default(work_report)
  number       String
  status       ProtocolStatus     @default(draft)
  title        String?

  // Parties (JSON snapshots for PDF immutability)
  supplierSnapshot Json?
  customerSnapshot Json?

  // Request metadata
  requesterName   String?
  dispatcherName  String?
  resolverName    String?
  categoryLabel   String?
  activityLabel   String?
  spaceLabel      String?
  tenantUnitLabel String?
  description     String? @db.Text
  publicNote      String? @db.Text
  internalNote    String? @db.Text

  // Dates
  submittedAt DateTime?
  dueAt       DateTime?
  completedAt DateTime?

  // Transport
  transportKm          Float?
  transportMode        String?
  transportDescription String? @db.Text

  // Handover & quality
  handoverAt          DateTime?
  satisfaction        Satisfaction?
  satisfactionComment String?       @db.Text

  // Signatures
  supplierSignatureName String?
  customerSignatureName String?
  supplierSignedAt      DateTime?
  customerSignedAt      DateTime?

  // Generated / uploaded documents
  generatedPdfDocumentId String?
  signedDocumentId       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property         Property?      @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  generatedPdfDoc  Document?      @relation("ProtocolGeneratedPdf", fields: [generatedPdfDocumentId], references: [id], onDelete: SetNull)
  signedDoc        Document?      @relation("ProtocolSignedDoc", fields: [signedDocumentId], references: [id], onDelete: SetNull)
  lines            ProtocolLine[]

  @@index([tenantId])
  @@index([tenantId, sourceType, sourceId])
  @@index([tenantId, status])
  @@index([tenantId, propertyId])
  @@map("protocols")
}

model ProtocolLine {
  id          String   @id @default(uuid())
  protocolId  String
  lineType    String   @default("labor") // labor, material, transport, other
  name        String
  unit        String?
  quantity    Float    @default(1)
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  protocol Protocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  @@index([protocolId])
  @@map("protocol_lines")
}

// ─── REVISIONS & COMPLIANCE ───────────────────────────────────────

model RevisionSubject {
  id           String   @id @default(uuid())
  tenantId     String
  propertyId   String?
  assetId      String?
  name         String
  category     String   @default("obecne")
  description  String?  @db.Text
  location     String?
  assetTag     String?
  manufacturer String?
  model        String?
  serialNumber String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property Property?      @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  asset    Asset?         @relation("AssetRevisionSubjects", fields: [assetId], references: [id], onDelete: SetNull)
  plans    RevisionPlan[]

  @@index([tenantId])
  @@index([tenantId, propertyId])
  @@index([assetId])
  @@map("revision_subjects")
}

model RevisionType {
  id                        String   @id @default(uuid())
  tenantId                  String
  code                      String
  name                      String
  description               String?  @db.Text
  defaultIntervalDays       Int      @default(365)
  defaultReminderDaysBefore Int      @default(30)
  color                       String?
  isActive                    Boolean  @default(true)
  requiresProtocol            Boolean  @default(false)
  defaultProtocolType         String?
  requiresSupplierSignature   Boolean  @default(false)
  requiresCustomerSignature   Boolean  @default(false)
  graceDaysAfterEvent         Int      @default(14)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  tenant              Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plans               RevisionPlan[]
  assetTypeAssignments AssetTypeRevisionType[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("revision_types")
}

enum RevisionPlanStatus {
  active
  paused
  archived
}

model RevisionPlan {
  id                     String             @id @default(uuid())
  tenantId               String
  propertyId             String?
  revisionSubjectId      String
  revisionTypeId         String
  assetId                String?
  assetTypeAssignmentId  String?
  title                  String
  description            String?            @db.Text
  intervalDays           Int
  reminderDaysBefore     Int                @default(30)
  vendorName             String?
  responsibleUserId      String?
  lastPerformedAt        DateTime?
  nextDueAt              DateTime
  status                 RevisionPlanStatus @default(active)
  isMandatory            Boolean            @default(true)
  generatedFromAssetType Boolean            @default(false)
  isCustomized           Boolean            @default(false)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  tenant              Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property            Property?               @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  revisionSubject     RevisionSubject         @relation(fields: [revisionSubjectId], references: [id], onDelete: Cascade)
  revisionType        RevisionType            @relation(fields: [revisionTypeId], references: [id], onDelete: Cascade)
  responsibleUser     User?                   @relation(fields: [responsibleUserId], references: [id], onDelete: SetNull)
  asset               Asset?                  @relation("AssetRevisionPlans", fields: [assetId], references: [id], onDelete: SetNull)
  assetTypeAssignment  AssetTypeRevisionType?   @relation(fields: [assetTypeAssignmentId], references: [id], onDelete: SetNull)
  events               RevisionEvent[]
  fieldCheckExecutions AssetFieldCheckExecution[]

  @@index([tenantId])
  @@index([tenantId, propertyId, nextDueAt])
  @@index([tenantId, status])
  @@index([revisionSubjectId])
  @@index([revisionTypeId])
  @@index([assetId])
  @@index([assetTypeAssignmentId])
  @@map("revision_plans")
}

enum RevisionResultStatus {
  passed
  passed_with_notes
  failed
  cancelled
  planned
}

model RevisionEvent {
  id                 String               @id @default(uuid())
  tenantId           String
  propertyId         String?
  revisionPlanId     String
  scheduledAt        DateTime?
  performedAt        DateTime?
  validUntil         DateTime?
  resultStatus       RevisionResultStatus @default(planned)
  summary            String?
  notes              String?              @db.Text
  vendorName         String?
  performedBy        String?
  protocolDocumentId String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property     Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  revisionPlan RevisionPlan @relation(fields: [revisionPlanId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, revisionPlanId, performedAt])
  @@index([revisionPlanId])
  @@map("revision_events")
}

// ─── DOCUMENTS ────────────────────────────────────────────────────

model Document {
  id           String      @id @default(uuid())
  tenantId     String
  name         String
  originalName String
  mimeType     String
  size         Int
  storageKey   String      @unique
  storageType  StorageType @default(local)
  category     DocCategory @default(other)
  description  String?
  isPublic     Boolean     @default(false)
  createdById  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?          @relation(fields: [createdById], references: [id], onDelete: SetNull)
  tags                   DocumentTag[]
  links                  DocumentLink[]
  protocolsAsGeneratedPdf Protocol[]    @relation("ProtocolGeneratedPdf")
  protocolsAsSignedDoc    Protocol[]    @relation("ProtocolSignedDoc")

  @@index([tenantId])
  @@index([tenantId, category])
  @@index([tenantId, createdAt])
  @@map("documents")
}

enum StorageType {
  local
  s3
}

enum DocCategory {
  contract
  invoice
  protocol
  photo
  plan
  regulation
  other
}

model DocumentTag {
  id         String   @id @default(uuid())
  documentId String
  tag        String
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, tag])
  @@index([tag])
  @@map("document_tags")
}

model DocumentLink {
  id         String     @id @default(uuid())
  documentId String
  entityType EntityType
  entityId   String
  createdAt  DateTime   @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@map("document_links")
}

enum EntityType {
  property
  unit
  resident
  ticket
  prescription
  reminder
  protocol
  revision
  asset
  work_order
  invoice
}

// ─── MIO FINDINGS ─────────────────────────────────────────────────

model MioFinding {
  id              String    @id @default(uuid())
  tenantId        String
  propertyId      String?
  kind            String    @default("finding")  // finding | recommendation
  code            String
  title           String
  description     String?   @db.Text
  category        String?   // efficiency | security | adoption | integration | data_quality
  severity        String    @default("info")
  confidence      String    @default("high")
  status          String    @default("active")
  entityType      String?
  entityId        String?
  entityCount     Int?
  fingerprint     String    @unique
  actionLabel     String?
  actionUrl       String?
  helpdeskTicketId String?
  ticketCreatedAutomatically Boolean @default(false)
  firstDetectedAt DateTime  @default(now())
  lastDetectedAt  DateTime  @default(now())
  resolvedAt      DateTime?
  dismissedAt     DateTime?
  snoozedUntil    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, severity, status])
  @@map("mio_findings")
}

// ─── SCHEDULED REPORTS ────────────────────────────────────────────

model ScheduledReportSubscription {
  id         String              @id @default(uuid())
  tenantId   String
  userId     String
  reportType ReportType
  frequency  ReportFrequency     @default(daily)
  format     ReportFormat        @default(xlsx)
  propertyId String?
  isEnabled  Boolean             @default(true)
  lastSentAt DateTime?
  metadata   Json?               // type-specific extra config (e.g. Mio digest prefs)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId])
  @@index([isEnabled, frequency])
  @@map("scheduled_report_subscriptions")
}

model MioDigestLog {
  id                   String   @id @default(uuid())
  tenantId             String
  userId               String
  frequency            String   // daily | weekly
  status               String   // sent | skipped | failed
  findingsCount        Int      @default(0)
  recommendationsCount Int      @default(0)
  skippedReason        String?
  createdAt            DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId, createdAt])
  @@map("mio_digest_logs")
}

model MioJobRunLog {
  id           String   @id @default(uuid())
  jobType      String   // detection | digest_daily | digest_weekly
  status       String   // success | partial | failed
  startedAt    DateTime
  finishedAt   DateTime @default(now())
  tenantCount  Int      @default(0)
  itemsCreated Int      @default(0)
  itemsResolved Int     @default(0)
  emailsSent   Int      @default(0)
  skippedCount Int      @default(0)
  failureCount Int      @default(0)
  summary      String?
  createdAt    DateTime @default(now())

  @@index([jobType, createdAt])
  @@map("mio_job_run_logs")
}

model MioWebhookSubscription {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  endpointUrl String
  secret      String   // HMAC signing secret
  isEnabled   Boolean  @default(true)
  eventTypes  String[] // e.g. ["mio.finding.created", "mio.finding.resolved"]
  kindFilter  String?  // finding | recommendation | null (all)
  minSeverity String?  // critical | warning | info | null (all)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deliveries MioWebhookDeliveryLog[]
  outbox     MioWebhookOutbox[]

  @@index([tenantId])
  @@index([tenantId, isEnabled])
  @@map("mio_webhook_subscriptions")
}

model MioWebhookDeliveryLog {
  id             String   @id @default(uuid())
  subscriptionId String
  eventId        String
  eventType      String
  attemptedAt    DateTime @default(now())
  status         String   // sent | failed | exhausted
  httpStatus     Int?
  retryCount     Int      @default(0)
  errorSummary   String?
  createdAt      DateTime @default(now())

  subscription MioWebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, createdAt])
  @@index([eventId])
  @@map("mio_webhook_delivery_logs")
}

model MioWebhookOutbox {
  id             String    @id @default(uuid())
  subscriptionId String
  eventId        String
  eventType      String
  payload        Json      // serialized MioEvent
  status         String    @default("pending") // pending | processing | sent | failed | exhausted
  retryCount     Int       @default(0)
  maxRetries     Int       @default(3)
  nextAttemptAt  DateTime  @default(now())
  lastAttemptAt  DateTime?
  lastHttpStatus Int?
  lastError      String?
  processedAt    DateTime?
  createdAt      DateTime  @default(now())

  subscription MioWebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([status, nextAttemptAt])
  @@index([subscriptionId])
  @@map("mio_webhook_outbox")
}

// ─── MIO CONVERSATIONS ──────────────────────────────────────────────

model MioConversation {
  id          String       @id @default(cuid())
  tenantId    String
  userId      String
  title       String?
  context     Json?        // { propertyId?, entityType?, entityId? }
  starred     Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  messages    MioMessage[]

  @@index([tenantId, userId])
  @@index([tenantId, updatedAt])
  @@map("mio_conversations")
}

model MioMessage {
  id              String          @id @default(cuid())
  conversationId  String
  role            String          // 'user' | 'assistant' | 'system'
  content         String          @db.Text
  toolCalls       Json?
  toolResults     Json?
  tokens          Int?
  createdAt       DateTime        @default(now())

  conversation    MioConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("mio_messages")
}

enum ReportType {
  daily_digest
  mio_digest
  operations
  assets
  protocols
}

enum ReportFrequency {
  daily
  weekly
  monthly
}

enum ReportFormat {
  xlsx
  csv
  email_only
}

// ─── SETTINGS ─────────────────────────────────────────────────────

model TenantSettings {
  id       String @id @default(uuid())
  tenantId String @unique

  // Firma
  orgName       String?
  orgStreet     String?
  orgCity       String?
  orgZip        String?
  orgCountry    String? @default("CZ")
  orgPhone      String?
  orgEmail      String?
  orgWeb        String?
  companyNumber String?
  vatNumber     String?

  // Branding
  logoBase64   String? @db.Text
  logoUrl      String?
  primaryColor String? @default("#6366f1")
  themeMode    String? @default("light")

  // Regional
  timezone   String  @default("Europe/Prague")
  currency   String  @default("CZK")
  language   String  @default("cs")
  dateFormat String? @default("DD.MM.YYYY")

  // Email
  emailFrom        String?
  emailReplyTo     String?
  emailSignature   String? @db.Text
  notifNewTicket   Boolean @default(true)
  notifWoAssigned  Boolean @default(true)
  notifContractExp Boolean @default(true)
  notifMeterDue    Boolean @default(true)
  notifPaymentDue  Boolean @default(true)

  // Invoicing
  invoicePrefix  String? @default("FV")
  contractPrefix String? @default("SM")
  invoiceDueDays Int     @default(14)
  defaultVat     Int     @default(21)
  invoiceFooter  String? @db.Text
  bankAccount    String?

  // Reminders
  reminderDaysBefore Int     @default(7)
  reminderText1      String? @db.Text
  reminderText2      String? @db.Text

  address String?

